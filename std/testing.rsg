// std/testing.rsg — generic test assertion helpers
//
// Usage: mod testing
//        use self::testing::assert_eq

mod conv
use self::conv::Display
use self::conv::Eq

/// Assert two values are equal. Panics with a diagnostic message on failure.
pub fn assert_eq<T: Eq + Display>(actual: T, expected: T) {
    if !actual.eq(expected) {
        panic("assertion failed: expected {expected.display()}, got {actual.display()}")
    }
}

/// Assert two values are not equal. Panics with a diagnostic message on failure.
pub fn assert_ne<T: Eq + Display>(actual: T, expected: T) {
    if actual.eq(expected) {
        panic("assertion failed: values should differ, both are {actual.display()}")
    }
}
