// std/prelude.rsg — optional prelude (auto-imported unless --no-prelude)
//
// Core types (Option, Result) and primitives (assert, len, panic,
// recover, print, println) are provided by std/builtin.rsg, which
// is always injected.
//
// This file re-exports the fundamental pacts (Display, Eq, Ord, Into)
// and generic utility functions (to_string, max, min, clamp) from the
// conv module so they are available by default in all user programs.

mod conv
pub use self::conv::*
