// std/builtin/ops.rsg — built-in operations
//
// These are compiler-intrinsic functions with special behavior:
//   assert  — injects file/line; accepts optional message
//   len     — works on str, slices, and arrays
//   panic   — triggers panic with message; returns never
//   recover — catches panic in a defer block; returns ?str

pub declare fn assert(cond: bool)
pub declare fn len(value: str) -> i32
pub declare fn panic(msg: str)
pub declare fn recover() -> str
