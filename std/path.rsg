// std/path.rsg — file path manipulation (pure string, no I/O)
//
// Usage: mod path
//        use self::path::join

pub decl fn join(a: str, b: str) -> str
pub decl fn file_name(path: str) -> str
pub decl fn dir(path: str) -> str
pub decl fn extension(path: str) -> str
pub decl fn is_absolute(path: str) -> bool
