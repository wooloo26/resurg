{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile-extension",
      "type": "shell",
      "command": "pnpm run compile",
      "options": {
        "cwd": "${workspaceFolder}/tools/rsg-lsp/editors/vscode"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "watch-extension",
      "type": "shell",
      "command": "pnpm run watch",
      "options": {
        "cwd": "${workspaceFolder}/tools/rsg-lsp/editors/vscode"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}
