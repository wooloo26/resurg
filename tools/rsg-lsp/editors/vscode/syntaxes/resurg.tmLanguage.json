{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Resurg",
  "scopeName": "source.resurg",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#function-definition" },
    { "include": "#keywords" },
    { "include": "#type-with-generics" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.resurg",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.resurg",
          "match": "//.*$"
        },
        {
          "name": "comment.block.resurg",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.resurg",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.resurg",
              "match": "\\\\[nrt0\\\\\"']"
            },
            {
              "name": "constant.character.escape.unicode.resurg",
              "match": "\\\\u\\{[0-9a-fA-F]{1,6}\\}"
            },
            {
              "name": "meta.interpolation.resurg",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.resurg" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.resurg" }
              },
              "patterns": [
                { "include": "source.resurg" }
              ]
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.resurg",
          "match": "'(?:\\\\[nrt0\\\\'\"]|\\\\u\\{[0-9a-fA-F]{1,6}\\}|[^'\\\\])'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.resurg",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.resurg",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.octal.resurg",
          "match": "\\b0o[0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.float.resurg",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.resurg",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "generic-type-parameters": {
      "comment": "Generic type parameter list in declarations: <T>, <T: Bound + Ord>",
      "begin": "<",
      "end": ">",
      "beginCaptures": {
        "0": { "name": "punctuation.bracket.resurg" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.resurg" }
      },
      "patterns": [
        { "include": "#comments" },
        {
          "comment": "comptime keyword before type parameter",
          "match": "\\b(comptime)\\b",
          "name": "keyword.other.resurg"
        },
        {
          "comment": "Type parameter with bound lookahead: T before :",
          "match": "\\b([A-Z][A-Za-z0-9]*)(?=\\s*:(?!:))",
          "captures": {
            "1": { "name": "entity.name.type.parameter.resurg" }
          }
        },
        {
          "comment": "Constraint colon (not ::)",
          "match": ":(?!:)",
          "name": "keyword.operator.colon.resurg"
        },
        {
          "comment": "Bound combiner +",
          "match": "\\+",
          "name": "keyword.operator.arithmetic.resurg"
        },
        {
          "comment": "Default type =",
          "match": "=",
          "name": "keyword.operator.assignment.resurg"
        },
        { "include": "#type-with-generics" },
        { "include": "#types" },
        { "include": "#punctuation" }
      ]
    },
    "type-with-generics": {
      "comment": "Type with generic arguments: Option<T>, Into<str>, Vec<i32>",
      "begin": "\\b([A-Z][A-Za-z0-9]*)(<)(?![<=])",
      "end": ">",
      "beginCaptures": {
        "1": { "name": "entity.name.type.resurg" },
        "2": { "name": "punctuation.bracket.resurg" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.resurg" }
      },
      "patterns": [
        { "include": "#comments" },
        {
          "comment": "Constraint colon inside generic args",
          "match": ":(?!:)",
          "name": "keyword.operator.colon.resurg"
        },
        {
          "comment": "Bound combiner +",
          "match": "\\+",
          "name": "keyword.operator.arithmetic.resurg"
        },
        { "include": "#type-with-generics" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#punctuation" }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "comment": "Function definition: fn name<...>(...)",
          "begin": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*[<(])",
          "end": "\\)",
          "beginCaptures": {
            "1": { "name": "storage.type.fn.resurg" },
            "2": { "name": "entity.name.function.resurg" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.bracket.round.resurg" }
          },
          "patterns": [
            { "include": "#generic-type-parameters" },
            { "include": "#comments" },
            {
              "match": "\\b(self)\\b",
              "name": "variable.language.self.resurg"
            },
            {
              "comment": "Typed parameter: name before colon",
              "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=:)",
              "captures": { "1": { "name": "variable.parameter.resurg" } }
            },
            {
              "comment": "Bare parameter (receiver or untyped) after ( or ,",
              "match": "(?<=[,(])\\s*([a-z_][a-z0-9_]*)(?=\\s*[,)])",
              "captures": { "1": { "name": "variable.parameter.resurg" } }
            },
            { "include": "#type-with-generics" },
            { "include": "#types" },
            { "include": "#constants" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        },
        {
          "comment": "Function name after fn keyword (no parens visible yet)",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.fn.resurg" },
            "2": { "name": "entity.name.function.resurg" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.resurg",
          "match": "\\b(?:if|else|while|for|loop|break|continue|match|return|defer|catch)\\b"
        },
        {
          "name": "keyword.declaration.resurg",
          "match": "\\b(?:ext|impl|mod|use|decl)\\b"
        },
        {
          "name": "keyword.other.resurg",
          "match": "\\b(?:pub|mut|where|as|is|in|comptime)\\b"
        },
        {
          "name": "variable.language.self.resurg",
          "match": "\\bself\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "fn/Fn/FnMut/Self and primitive types",
          "name": "storage.type.primitive.resurg",
          "match": "\\b(?:type|struct|enum|var|pact|immut|Fn|FnMut|Self|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|bool|char|str|usize|isize|unit|never)\\b"
        },
        {
          "comment": "Return type arrow",
          "name": "storage.type.primitive.resurg",
          "match": "->"
        },
        {
          "name": "entity.name.type.resurg",
          "match": "\\b[A-Z][A-Za-z0-9]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.resurg",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.option.resurg",
          "match": "\\b(?:Some|None)\\b"
        },
        {
          "name": "constant.language.result.resurg",
          "match": "\\b(?:Ok|Err)\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "support.function.builtin.resurg",
          "match": "\\b(?:println|print|assert|panic|catch_panic|len)\\b"
        },
        {
          "comment": "Function/method call: name(",
          "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.resurg" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.namespace.resurg",
          "match": "::"
        },
        {
          "name": "keyword.operator.pipe.resurg",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.colon.resurg",
          "match": ":"
        },
        {
          "name": "keyword.operator.optional-chain.resurg",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.range.resurg",
          "match": "\\.\\.=?"
        },
        {
          "name": "keyword.operator.comparison.resurg",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.resurg",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.assignment.resurg",
          "match": ":=|\\+=|-=|\\*=|/=|="
        },
        {
          "name": "keyword.operator.arithmetic.resurg",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.not.resurg",
          "match": "!"
        },
        {
          "name": "keyword.operator.try.resurg",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.reference.resurg",
          "match": "[&*]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.resurg",
          "match": "[;,]"
        },
        {
          "name": "punctuation.bracket.resurg",
          "match": "[{}()\\[\\]]"
        }
      ]
    }
  }
}
