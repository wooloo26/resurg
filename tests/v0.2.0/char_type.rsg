// v0.2.0 — char type
module test_char_type

// ── basic char values ──
fn test_char_literals() {
    var a: char = 'A'
    var b: char = 'z'
    var c: char = '0'
    var d: char = ' '
    assert(a == 'A')
    assert(b == 'z')
    assert(c == '0')
    assert(d == ' ')
}

// ── char comparisons ──
fn test_char_comparisons() {
    var a: char = 'A'
    var b: char = 'B'
    assert(a < b)
    assert(b > a)
    assert(a <= a)
    assert(b >= b)
    assert(a != b)
    assert(a == a)
}

// ── char inference ──
fn test_char_inference() {
    c := 'x'
    assert(c == 'x')
}

// ── special characters ──
fn test_char_special() {
    newline := '\n'
    tab := '\t'
    backslash := '\\'
    single_quote := '\''
    null_char := '\0'
    assert(newline == '\n')
    assert(tab == '\t')
    assert(backslash == '\\')
    assert(single_quote == '\'')
    assert(null_char == '\0')
}

// ── char in function parameter ──
fn is_upper(c: char) -> bool {
    c >= 'A' && c <= 'Z'
}

fn is_digit(c: char) -> bool {
    c >= '0' && c <= '9'
}

fn test_char_functions() {
    assert(is_upper('A') == true)
    assert(is_upper('Z') == true)
    assert(is_upper('a') == false)
    assert(is_upper('0') == false)
    assert(is_digit('0') == true)
    assert(is_digit('9') == true)
    assert(is_digit('a') == false)
}

// ── char equality across variables ──
fn test_char_equality() {
    var a: char = 'Q'
    var b: char = 'Q'
    var c: char = 'R'
    assert(a == b)
    assert(a != c)
}

fn main() {
    test_char_literals()
    test_char_comparisons()
    test_char_inference()
    test_char_special()
    test_char_functions()
    test_char_equality()
}
