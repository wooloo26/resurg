// v0.1.0 — Integration tests combining multiple features
module test_integration

// ── FizzBuzz ──
fn fizzbuzz(n: i32) -> str {
    if n % 15 == 0 {
        "FizzBuzz"
    } else if n % 3 == 0 {
        "Fizz"
    } else if n % 5 == 0 {
        "Buzz"
    } else {
        "{n}"
    }
}

fn test_fizzbuzz() {
    assert fizzbuzz(1) == "1"
    assert fizzbuzz(3) == "Fizz"
    assert fizzbuzz(5) == "Buzz"
    assert fizzbuzz(15) == "FizzBuzz"
    assert fizzbuzz(30) == "FizzBuzz"
    assert fizzbuzz(7) == "7"
    assert fizzbuzz(9) == "Fizz"
    assert fizzbuzz(10) == "Buzz"
}

// ── Fibonacci ──
fn fib(n: i32) -> i32 {
    if n <= 0 { 0 }
    else if n == 1 { 1 }
    else {
        a := 0
        b := 1
        i := 2
        loop {
            if i > n { break }
            temp := a + b
            a = b
            b = temp
            i = i + 1
        }
        b
    }
}

fn test_fibonacci() {
    assert fib(0) == 0
    assert fib(1) == 1
    assert fib(2) == 1
    assert fib(3) == 2
    assert fib(4) == 3
    assert fib(5) == 5
    assert fib(10) == 55
    assert fib(20) == 6765
}

// ── Power ──
fn power(base: i32, exp: i32) -> i32 {
    result := 1
    for 0..exp |i| {
        result = result * base
    }
    result
}

fn test_power() {
    assert power(2, 0) == 1
    assert power(2, 1) == 2
    assert power(2, 10) == 1024
    assert power(3, 3) == 27
    assert power(5, 4) == 625
    assert power(1, 100) == 1
}

// ── GCD ──
fn gcd(a: i32, b: i32) -> i32 {
    x := a
    y := b
    loop {
        if y == 0 { break }
        temp := y
        y = x % y
        x = temp
    }
    x
}

fn test_gcd() {
    assert gcd(12, 8) == 4
    assert gcd(100, 75) == 25
    assert gcd(17, 13) == 1
    assert gcd(0, 5) == 5
    assert gcd(7, 7) == 7
}

// ── Is prime ──
fn is_prime(n: i32) -> bool {
    if n < 2 { false }
    else {
        result := true
        i := 2
        loop {
            if i * i > n { break }
            if n % i == 0 {
                result = false
                break
            }
            i = i + 1
        }
        result
    }
}

fn test_is_prime() {
    assert is_prime(0) == false
    assert is_prime(1) == false
    assert is_prime(2) == true
    assert is_prime(3) == true
    assert is_prime(4) == false
    assert is_prime(17) == true
    assert is_prime(25) == false
    assert is_prime(97) == true
}

// ── Combining string interpolation + loop + if ──
fn classify(n: i32) -> str {
    if n > 0 { "positive" }
    else if n < 0 { "negative" }
    else { "zero" }
}

fn test_classify() {
    assert classify(42) == "positive"
    assert classify(-7) == "negative"
    assert classify(0) == "zero"

    // build a summary with interpolation
    val := 99
    summary := "{val} is {classify(val)}"
    assert summary == "99 is positive"
}

// ── Sum of digits ──
fn sum_digits(n: i32) -> i32 {
    num := n
    sum := 0
    loop {
        if num == 0 { break }
        sum = sum + num % 10
        num = num / 10
    }
    sum
}

fn test_sum_digits() {
    assert sum_digits(123) == 6
    assert sum_digits(9999) == 36
    assert sum_digits(100) == 1
    assert sum_digits(0) == 0
}

// ── Collatz steps ──
fn collatz_steps(n: i32) -> i32 {
    steps := 0
    current := n
    loop {
        if current == 1 { break }
        if current % 2 == 0 {
            current = current / 2
        } else {
            current = current * 3 + 1
        }
        steps = steps + 1
    }
    steps
}

fn test_collatz() {
    assert collatz_steps(1) == 0
    assert collatz_steps(2) == 1
    assert collatz_steps(6) == 8
    assert collatz_steps(27) == 111
}

// ── Recursive countdown to string ──
fn countdown(n: i32) -> str {
    if n <= 0 { "done" }
    else { "{n} {countdown(n - 1)}" }
}

fn test_recursive_string() {
    assert countdown(0) == "done"
    assert countdown(1) == "1 done"
    assert countdown(3) == "3 2 1 done"
}

// ── for + if + interpolation: build comma-separated list ──
fn range_list(n: i32) -> str {
    result := ""
    for 0..n |i| {
        if i == 0 {
            result = "{i}"
        } else {
            result = "{result}, {i}"
        }
    }
    result
}

fn test_range_list() {
    assert range_list(0) == ""
    assert range_list(1) == "0"
    assert range_list(4) == "0, 1, 2, 3"
}

// ── Absolute difference using functions + if/else ──
fn abs_diff(a: i32, b: i32) -> i32 {
    diff := a - b
    if diff < 0 { -diff } else { diff }
}

fn test_abs_diff() {
    assert abs_diff(10, 3) == 7
    assert abs_diff(3, 10) == 7
    assert abs_diff(5, 5) == 0
}

// ── Nested loop multiplication table sum ──
fn mul_table_sum(n: i32) -> i32 {
    total := 0
    for 1..n |i| {
        for 1..n |j| {
            total = total + i * j
        }
    }
    total
}

fn test_mul_table_sum() {
    // 1*1 = 1
    assert mul_table_sum(2) == 1
    // 1*1 + 1*2 + 2*1 + 2*2 = 1+2+2+4 = 9
    assert mul_table_sum(3) == 9
}

// ── f64 integration: distance formula (manual sqrt via Newton's method) ──
fn sqrt_approx(x: f64) -> f64 {
    guess := x / 2.0
    for 0..20 |i| {
        guess = (guess + x / guess) / 2.0
    }
    guess
}

fn test_sqrt_approx() {
    r := sqrt_approx(4.0)
    assert r > 1.99
    assert r < 2.01

    r2 := sqrt_approx(9.0)
    assert r2 > 2.99
    assert r2 < 3.01
}

// ── pub + private + loop + for combined ──
pub fn count_primes_below(limit: i32) -> i32 {
    count := 0
    for 2..limit |n| {
        if is_prime(n) {
            count = count + 1
        }
    }
    count
}

fn test_count_primes() {
    assert count_primes_below(2) == 0
    assert count_primes_below(10) == 4   // 2, 3, 5, 7
    assert count_primes_below(20) == 8   // 2,3,5,7,11,13,17,19
}

fn main() {
    test_fizzbuzz()
    test_fibonacci()
    test_power()
    test_gcd()
    test_is_prime()
    test_classify()
    test_sum_digits()
    test_collatz()
    test_recursive_string()
    test_range_list()
    test_abs_diff()
    test_mul_table_sum()
    test_sqrt_approx()
    test_count_primes()
}
