-- input.rsg --
struct Pair {
    a: i32 = 0
    b: i32 = 0
}
ext Pair {
    fn sum(self) -> i32 {
        return self.a + self.b
    }
    fn swap(mut *self) {
        tmp := self.a
        self.a = self.b
        self.b = tmp
    }
    fn create(x: i32, y: i32) -> Pair {
        return Pair { a = x, b = y }
    }
}
fn main() {
    p := Pair.create(1, 2)
    s := p.sum()
}
-- diagnostics --
