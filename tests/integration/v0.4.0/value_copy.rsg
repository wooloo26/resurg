// v0.4.0 — Value-type copy vs pointer copy semantics
module test_value_copy

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0
}

// ── struct value copy: copies are independent ──

fn test_struct_value_copy() {
    a := Point { x = 1.0, y = 2.0 }
    b := a
    b.x = 99.0
    assert(a.x == 1.0)
    assert(b.x == 99.0)
}

// ── pointer copy: aliases share same backing struct ──

fn test_pointer_copy_aliased() {
    a := &Point { x = 1.0, y = 2.0 }
    b := a
    b.x = 99.0
    assert(a.x == 99.0)
    assert(b.x == 99.0)
}

// ── reassign pointer: old alias unaffected ──

fn test_pointer_reassign() {
    a := &Point { x = 1.0, y = 2.0 }
    b := a
    a = &Point { x = 50.0, y = 60.0 }
    assert(a.x == 50.0)
    assert(b.x == 1.0)
}
