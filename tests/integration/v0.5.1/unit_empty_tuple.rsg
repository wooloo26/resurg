// v0.5.1 — Unit is a primitive type, not an empty tuple

// ── unit keyword is a valid unit literal ──

fn test_unit_literal() {
    x := unit
    assert(true)
}

// ── unit type annotation with unit value ──

fn test_unit_with_value() {
    var x: unit = unit
    assert(true)
}

// ── function returning unit implicitly ──

fn returns_unit() {
}

fn test_fn_returns_unit() {
    returns_unit()
    assert(true)
}

// ── function explicitly returning unit ──

fn explicit_unit() -> unit {
    unit
}

fn test_explicit_unit_return() {
    explicit_unit()
    assert(true)
}
