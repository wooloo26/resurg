// v0.5.1 — Return: early return from functions
module test_return

// ── early return with value ──

fn early_return_value(x: i32) -> i32 {
    if x > 0 { return x * 2 }
    0
}

fn test_return_with_value() {
    assert(early_return_value(5) == 10)
    assert(early_return_value(0) == 0)
    assert(early_return_value(-1) == 0)
}

// ── void return stops execution ──

fn stops_execution(mut p: *i32) {
    *p = 1
    return
    *p = 2
}

fn test_return_void() {
    x := 0
    stops_execution(mut &x)
    assert(x == 1)
}

// ── return in nested if ──

fn classify(x: i32) -> str {
    if x > 0 {
        return "positive"
    }
    if x < 0 {
        return "negative"
    }
    "zero"
}

fn test_return_nested_if() {
    assert(classify(10) == "positive")
    assert(classify(-5) == "negative")
    assert(classify(0) == "zero")
}

// ── return in loop ──

fn find_first_multiple(n: i32, target: i32) -> i32 {
    i := 1
    loop {
        if i * n >= target { return i * n }
        i = i + 1
    }
}

fn test_return_in_loop() {
    assert(find_first_multiple(7, 50) == 56)
    assert(find_first_multiple(3, 10) == 12)
}

// ── return unit explicitly ──

fn return_unit() {
    return
}

fn test_return_unit() {
    return_unit()
    assert(true)
}
