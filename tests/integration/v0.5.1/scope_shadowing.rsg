// v0.5.1 — Scope, shadowing, and block expressions

// ── inner scope shadowing ──

fn test_inner_scope_shadow() {
    x := 10
    {
        x := 20
        assert(x == 20)
    }
    assert(x == 10)
}

// ── same-scope rebinding ──

fn test_same_scope_rebinding() {
    x := 1
    assert(x == 1)
    x := 2
    assert(x == 2)
}

// ── shadowing changes type ──

fn test_shadow_changes_type() {
    x := 42
    assert(x == 42)
    x := true
    assert(x == true)
}

fn test_shadow_changes_type_to_string() {
    val := 100
    assert(val == 100)
    val := "hello"
    assert(val == "hello")
}

// ── block expression ──

fn test_block_expression() {
    x := 5
    y := {
        x_squared := x * x
        x_cube := x_squared * x
        x_cube + x_squared + x
    }
    assert(y == 155)
}

fn test_block_expression_simple() {
    x := 5
    z := {
        2 * x
    }
    assert(z == 10)
}

// ── empty block is unit ──

fn test_empty_block() {
    empty := {}
    assert(true)
}

// ── nested scoping ──

fn test_nested_scopes() {
    x := 1
    {
        x := 2
        {
            x := 3
            assert(x == 3)
        }
        assert(x == 2)
    }
    assert(x == 1)
}

// ── shadow in for loop body ──

fn test_shadow_in_loop() {
    x := 0
    for 0..3 |i| {
        x := i * 10
        assert(x == i * 10)
    }
    assert(x == 0)
}
