// v0.5.1 — Defer: LIFO cleanup on function exit

// ── basic defer modifies state before return ──

fn set_value(mut p: *i32, val: i32) {
    defer { *p = val }
}

fn test_defer_basic() {
    x := 0
    set_value(mut &x, 42)
    assert(x == 42)
}

// ── defer executes after function body ──

fn defer_after_body(mut p: *i32) {
    defer { *p = *p + 100 }
    *p = 5
}

fn test_defer_after_body() {
    x := 0
    defer_after_body(mut &x)
    assert(x == 105)
}

// ── LIFO order: last defer runs first ──

fn build_number(mut p: *i32) {
    defer { *p = *p * 10 + 1 }
    defer { *p = *p * 10 + 2 }
    defer { *p = *p * 10 + 3 }
}

fn test_defer_lifo_order() {
    result := 0
    build_number(mut &result)
    assert(result == 321)
}

// ── defer runs even with early return ──

fn defer_with_return(mut p: *i32) -> i32 {
    defer { *p = 42 }
    return 10
}

fn test_defer_with_return() {
    x := 0
    r := defer_with_return(mut &x)
    assert(r == 10)
    assert(x == 42)
}

// ── multiple defers with body interleaved ──

fn interleaved(mut p: *i32) {
    *p = *p + 1
    defer { *p = *p * 2 }
    *p = *p + 1
    defer { *p = *p * 3 }
    *p = *p + 1
}

fn test_defer_interleaved() {
    x := 0
    interleaved(mut &x)
    // body: x = 0+1=1, +1=2, +1=3
    // LIFO: second defer first: x = 3*3=9
    //        first defer second: x = 9*2=18
    assert(x == 18)
}
