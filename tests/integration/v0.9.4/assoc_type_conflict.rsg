// v0.9.4 — Associated type conflict resolution: qualified names for same-named types

pact A {
    type Value
}

pact B {
    type Value
}

struct Dual {
    a_val: i32
    b_val: str
}

ext Dual impl A + B {
    type A::Value = i32
    type B::Value = str
}

fn get_a_value<T: A>(t: T) -> i32 {
    t.a_val
}

fn test_conflict_resolution() {
    d := Dual { a_val = 42, b_val = "hello" }
    assert(d.a_val == 42)
    assert(d.b_val == "hello")
}
