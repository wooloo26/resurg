// v0.9.4 — Associated types integration with T ! E result types

// ── pact with associated types in result return ──

pact Fallible {
    type Value
    type Error

    fn try_get(mut *self) -> Self::Value ! Self::Error
}

// ── struct implementing Fallible ──

struct FallibleSource: Fallible {
    type Value = i32
    type Error = str

    current: i32
    fail_at: i32

    fn try_get(mut *self) -> i32 ! str {
        if self.current == self.fail_at {
            Err("fail")
        } else {
            val := self.current
            self.current = self.current + 1
            Ok(val)
        }
    }
}

fn test_fallible_ok() {
    src := FallibleSource { current = 0, fail_at = -1 }
    result := src.try_get()
    match result {
        Ok(v) => assert(v == 0),
        Err(_) => assert(false),
    }
}

fn test_fallible_err() {
    src := FallibleSource { current = 0, fail_at = 0 }
    result := src.try_get()
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e == "fail"),
    }
}

fn test_fallible_sequence() {
    src := FallibleSource { current = 0, fail_at = 2 }
    r1 := src.try_get()
    match r1 {
        Ok(v) => assert(v == 0),
        Err(_) => assert(false),
    }
    r2 := src.try_get()
    match r2 {
        Ok(v) => assert(v == 1),
        Err(_) => assert(false),
    }
    r3 := src.try_get()
    match r3 {
        Ok(_) => assert(false),
        Err(e) => assert(e == "fail"),
    }
}

// ── generic function with fallible associated types ──

fn try_first<F: Fallible>(mut src: *F) -> F::Value ! F::Error {
    src.try_get()
}

fn test_generic_fallible_ok() {
    src := FallibleSource { current = 5, fail_at = -1 }
    result := try_first<FallibleSource>(mut &src)
    match result {
        Ok(v) => assert(v == 5),
        Err(_) => assert(false),
    }
}

fn test_generic_fallible_err() {
    src := FallibleSource { current = 0, fail_at = 0 }
    result := try_first<FallibleSource>(mut &src)
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e == "fail"),
    }
}
