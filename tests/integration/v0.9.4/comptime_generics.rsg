// v0.9.4 — comptime generics: compile-time constant type parameters

// ── basic comptime parameter for array size ──

struct ArrayWrapper<T, comptime N: usize> {
    data: [N]T
}

fn test_arraywrapper_i32_5() {
    w := ArrayWrapper<i32, 5> { data = [1, 2, 3, 4, 5] }
    assert(w.data[0] == 1)
    assert(w.data[4] == 5)
}

fn test_arraywrapper_str_3() {
    w := ArrayWrapper<str, 3> { data = ["a", "b", "c"] }
    assert(w.data[0] == "a")
    assert(w.data[2] == "c")
}

// ── comptime with single type param ──

struct FixedBuffer<comptime N: usize> {
    data: [N]i32
}

fn test_fixed_buffer() {
    buf := FixedBuffer<4> { data = [10, 20, 30, 40] }
    assert(buf.data[0] == 10)
    assert(buf.data[3] == 40)
}

// ── multiple instantiations with different comptime values ──

fn test_multiple_sizes() {
    small := ArrayWrapper<i32, 2> { data = [1, 2] }
    large := ArrayWrapper<i32, 4> { data = [1, 2, 3, 4] }
    assert(small.data[0] == 1)
    assert(large.data[3] == 4)
}

// ── comptime with bool type ──

struct BoolArray<comptime N: usize> {
    flags: [N]bool
}

fn test_bool_array() {
    b := BoolArray<3> { flags = [true, false, true] }
    assert(b.flags[0] == true)
    assert(b.flags[1] == false)
    assert(b.flags[2] == true)
}
