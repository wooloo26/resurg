// v0.9.1 — Extension methods with pact implementation (retroactive conformance)

// ── pact definition ──

pact Describable {
    fn describe() -> str
}

// ── struct without built-in conformance ──

struct Widget {
    name: str
}

// ── ext implements pact for struct ──

ext Widget impl Describable {
    fn describe(*w) -> str {
        w.name
    }
}

fn test_ext_pact_basic() {
    w := Widget { name = "button" }
    assert(w.describe() == "button")
}

// ── ext impl with multiple methods (pact requires + extra) ──

pact Displayable {
    fn display() -> str
    fn short_display() -> str
}

struct Item {
    id: i32 = 0
    label: str
}

ext Item impl Displayable {
    fn display(*it) -> str {
        "{it.label}({it.id})"
    }

    fn short_display(*it) -> str {
        it.label
    }
}

fn test_ext_pact_multiple_methods() {
    it := Item { id = 42, label = "test" }
    assert(it.display() == "test(42)")
    assert(it.short_display() == "test")
}

// ── ext impl for enum ──

enum Color {
    Red,
    Green,
    Blue,
}

ext Color impl Describable {
    fn describe(*c) -> str {
        match c {
            Red => "red",
            Green => "green",
            Blue => "blue",
        }
    }
}

fn test_ext_pact_on_enum() {
    c := Color::Green
    assert(c.describe() == "green")
}

// ── ext impl pact with non-pact extra methods ──

ext Widget {
    fn upper_name(*w) -> str {
        w.name
    }
}

fn test_ext_with_extra_non_pact_methods() {
    w := Widget { name = "extra" }
    assert(w.upper_name() == "extra")
    assert(w.describe() == "extra")
}
