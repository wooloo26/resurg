// v0.9.1 — use imports with nested modules

// ── nested module definition ──

mod math {
    pub fn add(a: i32, b: i32) -> i32 = a + b
    pub fn multiply(a: i32, b: i32) -> i32 = a * b
    fn private_helper() -> i32 = 42
}

// ── qualified access without use ──

fn test_qualified_access() {
    result := math::add(2, 3)
    assert(result == 5)

    product := math::multiply(4, 5)
    assert(product == 20)
}

// ── use brings items into scope ──

use math { multiply }

fn test_use_import_single() {
    result := multiply(6, 7)
    assert(result == 42)
}

// ── use with alias ──

use math { add as sum }

fn test_use_alias() {
    result := sum(10, 20)
    assert(result == 30)
}
