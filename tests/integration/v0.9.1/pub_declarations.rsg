// v0.9.1 — pub visibility on all declaration types

// ── pub struct ──

pub struct PublicPoint {
    x: f64 = 0.0
    y: f64 = 0.0
}

fn test_pub_struct() {
    p := PublicPoint { x = 1.0, y = 2.0 }
    assert(p.x == 1.0)
    assert(p.y == 2.0)
}

// ── pub enum ──

pub enum PublicColor {
    Red,
    Green,
    Blue,
}

fn test_pub_enum() {
    c := PublicColor::Red
    match c {
        Red => assert(true),
        _ => assert(false),
    }
}

// ── pub type alias ──

pub type ID = u64

fn test_pub_type_alias() {
    var id: ID = u64(123)
    assert(id == u64(123))
}

// ── pub pact ──

pub pact Checkable {
    fn check() -> bool
}

struct Validator: Checkable {
    fn check(v) -> bool = true
}

fn test_pub_pact() {
    v := Validator {}
    assert(v.check())
}

// ── pub fn (already supported, verify still works) ──

pub fn public_add(a: i32, b: i32) -> i32 = a + b

fn test_pub_fn() {
    assert(public_add(2, 3) == 5)
}

// ── non-pub declarations (private by default) ──

struct PrivateStruct {
    value: i32 = 0
}

enum PrivateEnum { X, Y }

type PrivateAlias = i32

pact PrivatePact {
    fn private_method() -> i32
}

fn test_private_declarations_within_module() {
    s := PrivateStruct { value = 42 }
    assert(s.value == 42)

    e := PrivateEnum::X
    match e {
        X => assert(true),
        _ => assert(false),
    }

    var a: PrivateAlias = 10
    assert(a == 10)
}
