// Mutable pointer parameters

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0
}

// ── mut parameter allows mutation through pointer ──

fn set_x(mut p: *Point, x: f64) {
    p.x = x
}

fn set_both(mut p: *Point, x: f64, y: f64) {
    p.x = x
    p.y = y
}

fn test_mut_set_single() {
    p := &Point { x = 1.0, y = 2.0 }
    set_x(mut p, 10.0)
    assert(p.x == 10.0, "")
    assert(p.y == 2.0, "")
}

fn test_mut_set_both() {
    p := &Point { x = 1.0, y = 2.0 }
    set_both(mut p, 10.0, 20.0)
    assert(p.x == 10.0, "")
    assert(p.y == 20.0, "")
}

// ── mixing mut and non-mut pointer params ──

fn copy_point(src: *Point, mut dst: *Point) {
    dst.x = src.x
    dst.y = src.y
}

fn test_mixed_params() {
    src := &Point { x = 5.0, y = 6.0 }
    dst := &Point { x = 0.0, y = 0.0 }
    copy_point(src, mut dst)
    assert(dst.x == 5.0, "")
    assert(dst.y == 6.0, "")
    assert(src.x == 5.0, "")
}
