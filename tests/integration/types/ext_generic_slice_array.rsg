// Generic ext blocks for slices and arrays
// Tests: ext<T> []T and ext<T, comptime N: usize> [N]T
// EXPECT-STDOUT: generic ext slice/array ok

// ── ext<T> []T: declare fn len ──

// Per README § 13:
//   ext<T> []T { pub declare fn len(s) -> i32 }
// The prelude provides .len() on all slice types via this generic ext.

fn test_slice_len_i32() {
    s := []i32{10, 20, 30}
    assert(s.len() == 3, "")
}

fn test_slice_len_str() {
    s := []str{"hello", "world"}
    assert(s.len() == 2, "")
}

fn test_slice_len_bool() {
    s := []bool{true, false, true, false}
    assert(s.len() == 4, "")
}

fn test_slice_len_empty() {
    s := []i32{}
    assert(s.len() == 0, "")
}

fn test_slice_len_rvalue() {
    assert(([]i32{1, 2, 3}).len() == 3, "")
}

// ── ext<T, comptime N: usize> [N]T: declare fn len ──

// Per README § 13:
//   ext<T, comptime N: usize> [N]T { pub declare fn len(s) -> i32 }
// The prelude provides .len() on all array types via this generic ext.

fn test_array_len_i32() {
    arr := [3]i32{1, 2, 3}
    assert(arr.len() == 3, "")
}

fn test_array_len_str() {
    arr := [2]str{"a", "b"}
    assert(arr.len() == 2, "")
}

fn test_array_len_bool() {
    arr := [5]bool{true, false, true, false, true}
    assert(arr.len() == 5, "")
}

fn test_array_len_rvalue() {
    assert(([4]i32{1, 2, 3, 4}).len() == 4, "")
}

// ── user-defined generic ext on slices ──

// Users should be able to define their own methods on []T
// using ext<T> []T { fn method(s) -> ... { ... } }

ext<T> []T {
    fn is_empty(s) -> bool {
        s.len() == 0
    }
}

fn test_slice_user_method_i32() {
    s := []i32{1, 2, 3}
    assert(s.is_empty() == false, "")
}

fn test_slice_user_method_i32_empty() {
    s := []i32{}
    assert(s.is_empty() == true, "")
}

fn test_slice_user_method_str() {
    s := []str{"hello"}
    assert(s.is_empty() == false, "")
}

// ── user-defined generic ext on arrays ──

// Users should be able to define their own methods on [N]T
// using ext<T, comptime N: usize> [N]T { fn method(s) -> ... { ... } }

ext<T, comptime N: usize> [N]T {
    fn is_empty(s) -> bool {
        s.len() == 0
    }
}

fn test_array_user_method_i32() {
    arr := [3]i32{1, 2, 3}
    assert(arr.is_empty() == false, "")
}

fn test_array_user_method_str() {
    arr := [2]str{"a", "b"}
    assert(arr.is_empty() == false, "")
}

// ── multiple instantiations across different element types ──

fn test_multiple_slice_instantiations() {
    a := []i32{1, 2}
    b := []str{"x", "y", "z"}
    c := []bool{true}
    assert(a.len() == 2, "")
    assert(b.len() == 3, "")
    assert(c.len() == 1, "")

    assert(a.is_empty() == false, "")
    assert(b.is_empty() == false, "")
    assert(c.is_empty() == false, "")
}

fn test_multiple_array_instantiations() {
    a := [2]i32{1, 2}
    b := [3]str{"x", "y", "z"}
    c := [1]bool{true}
    assert(a.len() == 2, "")
    assert(b.len() == 3, "")
    assert(c.len() == 1, "")

    assert(a.is_empty() == false, "")
    assert(b.is_empty() == false, "")
    assert(c.is_empty() == false, "")
}

// ── .len() in expressions ──

fn test_len_in_expression() {
    s := []i32{10, 20, 30}
    total := s.len() + 1
    assert(total == 4, "")

    arr := [3]i32{1, 2, 3}
    sum := arr.len() * 2
    assert(sum == 6, "")
}

// ── pointer to slice auto-deref ──

fn test_ptr_slice_len() {
    s := []i32{1, 2, 3, 4}
    p := &s
    assert(p.len() == 4, "")
}

// ── sub-slice retains len ──

fn test_sub_slice_len() {
    s := []i32{1, 2, 3, 4, 5}
    t := s[1..4]
    assert(t.len() == 3, "")
}

fn test_final() {
    println("generic ext slice/array ok")
}
