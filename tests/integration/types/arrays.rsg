// Arrays ([N]T) — fixed-size value types

// ── array declaration and access ──
fn test_array_basic() {
    var arr: [3]i32 = [1, 2, 3]
    assert(arr[0] == 1)
    assert(arr[1] == 2)
    assert(arr[2] == 3)
}

// ── array with type-prefixed literal (inference) ──
fn test_array_inferred() {
    arr := [3]i32{10, 20, 30}
    assert(arr[0] == 10)
    assert(arr[1] == 20)
    assert(arr[2] == 30)
}

// ── array assignment ──
fn test_array_assignment() {
    var arr: [3]i32 = [0, 0, 0]
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    assert(arr[0] == 10)
    assert(arr[1] == 20)
    assert(arr[2] == 30)
}

// ── array with different types ──
fn test_array_bool() {
    var flags: [4]bool = [true, false, true, false]
    assert(flags[0] == true)
    assert(flags[1] == false)
    assert(flags[2] == true)
    assert(flags[3] == false)
}

fn test_array_f64() {
    var vals: [3]f64 = [1.1, 2.2, 3.3]
    assert(vals[0] == 1.1)
    assert(vals[1] == 2.2)
    assert(vals[2] == 3.3)
}

fn test_array_u8() {
    var bytes: [4]u8 = [0, 127, 200, 255]
    assert(bytes[0] == 0)
    assert(bytes[1] == 127)
    assert(bytes[2] == 200)
    assert(bytes[3] == 255)
}

// ── array in loops ──
fn test_array_loop() {
    var arr: [5]i32 = [10, 20, 30, 40, 50]
    total := 0
    for 0..5 |i| {
        total = total + arr[i]
    }
    assert(total == 150)
}

// ── array copy semantics (value type) ──
fn test_array_copy() {
    var a: [3]i32 = [1, 2, 3]
    var b: [3]i32 = a
    b[0] = 99
    // a should be unmodified (value copy)
    assert(a[0] == 1)
    assert(b[0] == 99)
}

// ── array passed to function ──
fn sum_array(arr: [4]i32) -> i32 {
    arr[0] + arr[1] + arr[2] + arr[3]
}

fn test_array_function() {
    var data: [4]i32 = [5, 10, 15, 20]
    assert(sum_array(data) == 50)
}

// ── array returned from function ──
fn make_pair(a: i32, b: i32) -> [2]i32 {
    [2]i32{a, b}
}

fn test_array_return() {
    var pair: [2]i32 = make_pair(42, 99)
    assert(pair[0] == 42)
    assert(pair[1] == 99)
}

// ── single element array ──
fn test_array_single() {
    var one: [1]i32 = [42]
    assert(one[0] == 42)
}

// ── array of chars ──
fn test_array_char() {
    var letters: [3]char = ['a', 'b', 'c']
    assert(letters[0] == 'a')
    assert(letters[1] == 'b')
    assert(letters[2] == 'c')
}

// ── nested array access in expressions ──
fn test_array_expression() {
    var arr: [3]i32 = [10, 20, 30]
    result := arr[0] + arr[1] * arr[2]
    assert(result == 610)
}

// ── array equality ──
fn test_array_equality() {
    a := [3]i32{1, 2, 3}
    b := [3]i32{1, 2, 3}
    c := [3]i32{3, 2, 1}
    assert(a == b)
    assert(a != c)
}
