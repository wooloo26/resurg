// Constraint alias expansion in type inference for generic bounds

// ── base pacts ──

pact Display {
    fn to_display() -> str
}

pact HasName {
    fn name() -> str
}

// ── constraint alias (brace syntax) ──

pact UserPrintable {
    Display
    HasName
}

// ── constraint alias (equals syntax) ──

pact ShowName = Display + HasName

// ── function using constraint alias as bound ──

fn show_printable<T: UserPrintable>(x: T) -> str {
    x.to_display()
}

fn show_combo<T: ShowName>(x: T) -> str {
    x.name()
}

// ── struct conforming to constraint alias ──

struct Person {
    person_name: str
}

ext Person impl UserPrintable {
    fn to_display(p) -> str {
        p.person_name
    }

    fn name(p) -> str {
        p.person_name
    }
}

struct User {
    user_name: str
}

ext User impl ShowName {
    fn to_display(u) -> str {
        u.user_name
    }

    fn name(u) -> str {
        u.user_name
    }
}

fn test_constraint_alias_brace() {
    p := Person { person_name = "Alice" }
    s := show_printable<Person>(p)
    assert(s == "Alice", "")
}

fn test_constraint_alias_equals() {
    u := User { user_name = "Bob" }
    s := show_combo<User>(u)
    assert(s == "Bob", "")
}
