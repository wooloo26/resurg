// Pointer types, heap allocation, auto-deref

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0
}

struct User {
    name: str
    age: i32
}

// ── heap allocation with & ──

fn test_heap_alloc_defaults() {
    p := &Point {}
    assert(p.x == 0.0, "")
    assert(p.y == 0.0, "")
}

fn test_heap_alloc_values() {
    p := &Point { x = 3.0, y = 4.0 }
    assert(p.x == 3.0, "")
    assert(p.y == 4.0, "")
}

fn test_heap_alloc_string_fields() {
    u := &User { name = "Alice", age = 30 }
    assert(u.name == "Alice", "")
    assert(u.age == 30, "")
}

// ── auto-deref field read ──

fn test_auto_deref_read() {
    p := &Point { x = 1.0, y = 2.0 }
    x := p.x
    y := p.y
    assert(x == 1.0, "")
    assert(y == 2.0, "")
}

// ── auto-deref field write ──

fn test_auto_deref_write() {
    p := &Point { x = 1.0, y = 2.0 }
    p.x = 10.0
    p.y = 20.0
    assert(p.x == 10.0, "")
    assert(p.y == 20.0, "")
}

// ── pointer aliasing ──

fn test_pointer_aliasing() {
    a := &Point { x = 1.0, y = 2.0 }
    b := a
    b.x = 99.0
    assert(a.x == 99.0, "")
    assert(b.x == 99.0, "")
}

// ── explicit pointer type annotation ──

fn test_explicit_pointer_type() {
    var p: *Point = &Point { x = 5.0, y = 6.0 }
    assert(p.x == 5.0, "")
    assert(p.y == 6.0, "")
}

// ── pointer as function parameter (read-only) ──

fn read_x(p: *Point) -> f64 {
    p.x
}

fn test_pointer_param_readonly() {
    p := &Point { x = 42.0, y = 0.0 }
    assert(read_x(p) == 42.0, "")
}

// ── pointer as return value ──

fn make_point(x: f64, y: f64) -> *Point {
    &Point { x = x, y = y }
}

fn test_pointer_return() {
    p := make_point(7.0, 8.0)
    assert(p.x == 7.0, "")
    assert(p.y == 8.0, "")
}

// ── pointer in loop ──

fn test_pointer_in_loop() {
    p := &Point { x = 0.0, y = 0.0 }
    for 0..5 |i| {
        p.x = p.x + 1.0
    }
    assert(p.x == 5.0, "")
}
