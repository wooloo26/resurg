// Generic methods on types: methods with own type parameters

// ── generic struct with a generic method ──

struct Pair<T, U> {
    first: T
    second: U
}

ext<T, U> Pair<T, U> {
    fn get_first(p) -> T {
        p.first
    }

    fn get_second(p) -> U {
        p.second
    }
}

fn test_pair_methods() {
    p := Pair<i32, str> { first = 42, second = "hello" }
    assert(p.get_first() == 42, "")
    assert(p.get_second() == "hello", "")
}

// ── non-generic struct with value receiver using generic params ──

struct Box<T> {
    value: T
}

ext<T> Box<T> {
    fn unwrap(b) -> T {
        b.value
    }
}

fn test_box_unwrap() {
    b := Box<i32> { value = 99 }
    assert(b.unwrap() == 99, "")

    s := Box<str> { value = "test" }
    assert(s.unwrap() == "test", "")
}
