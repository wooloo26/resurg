// Pact implementation on primitive types
// TEST: normal

pact Show {
    fn show_text() -> str
}

ext i32 impl Show {
    fn show_text(n) -> str = n.to_str()
}

ext f64 impl Show {
    fn show_text(n) -> str = n.to_str()
}

ext bool impl Show {
    fn show_text(b) -> str = b.to_str()
}

ext str impl Show {
    fn show_text(s) -> str = s
}

// Generic function bounded by Show
fn show<T: Show>(value: T) -> str {
    value.show_text()
}

fn test_primitive_display() {
    assert(show<i32>(42) == "42", "i32 display")
    assert(show<bool>(true) == "true", "bool display")
    assert(show<str>("hello") == "hello", "str display")
}

fn test_direct_call() {
    assert(42.show_text() == "42", "direct i32")
    assert(true.show_text() == "true", "direct bool")
    assert("hi".show_text() == "hi", "direct str")
}

// ── Convertible<T> pact on primitives ──

pact Convertible<T> {
    fn convert() -> T
}

ext i32 impl Convertible {
    fn convert(n) -> str = n.to_str()
}

fn convert_value<T: Convertible>(value: T) -> str {
    value.convert()
}

fn test_into() {
    var s: str = 42.convert()
    assert(s == "42", "i32 into str")
    assert(convert_value<i32>(100) == "100", "convert generic")
}

fn main() {
    test_primitive_display()
    test_direct_call()
    test_into()
    println("all pact primitive tests passed")
}

// EXPECT-STDOUT: all pact primitive tests passed
