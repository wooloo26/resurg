// Pact-bounded type parameters: single and multiple bounds

// ── pacts for bounds ──

pact Display {
    fn to_display() -> str
}

pact HasAge {
    fn age() -> i32
}

// ── single bound ──

fn show<T: Display>(x: T) -> str {
    x.to_display()
}

// ── multiple bounds with + syntax ──

fn describe<T: Display + HasAge>(x: T) -> str {
    s := x.to_display()
    s
}

// ── struct conforming to Display ──

struct Dog {
    dog_name: str
}

ext Dog impl Display {
    fn to_display(d) -> str {
        d.dog_name
    }
}

// ── struct conforming to Display + HasAge ──

struct Cat {
    cat_name: str
    cat_age: i32 = 0
}

ext Cat impl Display + HasAge {
    fn to_display(c) -> str {
        c.cat_name
    }

    fn age(c) -> i32 {
        c.cat_age
    }
}

fn test_single_bound() {
    d := Dog { dog_name = "Dog" }
    s := show<Dog>(d)
    assert(s == "Dog", "")
}

fn test_multiple_bounds() {
    c := Cat { cat_name = "Cat", cat_age = 5 }
    s := describe<Cat>(c)
    assert(s == "Cat", "")
}
