// Enum methods and complex enum usage

enum Msg {
    Quit,
    Move { x: i32, y: i32 },
    Write(str),
}

ext Msg {
    fn is_quit(*m) -> bool {
        match m {
            Quit => true,
            _ => false,
        }
    }

    fn describe(*m) -> str {
        match m {
            Quit => "quit",
            Move { x, y } => "move",
            Write(text) => text,
        }
    }
}

fn test_enum_method_call() {
    q := Msg::Quit
    assert(q.is_quit())
    assert(q.describe() == "quit")
}

fn test_enum_method_on_tuple() {
    w := Msg::Write("hello")
    assert(w.is_quit() == false)
    assert(w.describe() == "hello")
}

fn test_enum_method_on_struct_variant() {
    m := Msg::Move { x = 10, y = 20 }
    assert(m.is_quit() == false)
    assert(m.describe() == "move")
}

// ── mut pointer receiver in ext ──

enum Toggle {
    On,
    Off,
}

ext Toggle {
    fn is_on(*t) -> bool {
        match t {
            On => true,
            Off => false,
        }
    }

    fn flip(mut *t) {
        match t {
            On => { t = Toggle::Off },
            Off => { t = Toggle::On },
        }
    }
}

fn test_enum_mut_ext() {
    t := Toggle::On
    assert(t.is_on())
    t.flip()
    assert(t.is_on() == false)
    t.flip()
    assert(t.is_on())
}

// ── enum with explicit discriminants ──

enum Status {
    Active = 1,
    Inactive = 0,
    Pending = 2,
}

fn test_enum_discriminants() {
    s := Status::Active
    assert(true)
}
