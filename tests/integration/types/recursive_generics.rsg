// Recursive generics: generic types that reference themselves

// ── linked list node: recursive generic struct ──

struct Node<T> {
    value: T
    next: ?*Node<T>
}

fn test_single_node() {
    n := Node<i32> { value = 42, next = None }
    assert(n.value == 42)
}

fn test_two_nodes() {
    tail := &Node<i32> { value = 2, next = None }
    head := Node<i32> { value = 1, next = Some(tail) }
    assert(head.value == 1)
    match head.next {
        Some(n) => assert(n.value == 2),
        None => assert(false),
    }
}

fn test_three_nodes() {
    c := &Node<str> { value = "c", next = None }
    b := &Node<str> { value = "b", next = Some(c) }
    a := Node<str> { value = "a", next = Some(b) }
    assert(a.value == "a")
    match a.next {
        Some(n) => {
            assert(n.value == "b")
            match n.next {
                Some(m) => assert(m.value == "c"),
                None => assert(false),
            }
        },
        None => assert(false),
    }
}

// ── recursive generic with pointer ──

struct PtrNode<T> {
    value: T
    next: ?*PtrNode<T>
}

fn test_ptr_node() {
    tail := &PtrNode<i32> { value = 20, next = None }
    head := &PtrNode<i32> { value = 10, next = Some(tail) }
    assert(head.value == 10)
    match head.next {
        Some(n) => assert(n.value == 20),
        None => assert(false),
    }
}

// ── tree: recursive with multiple children ──

struct Tree<T> {
    value: T
    left: ?*Tree<T>
    right: ?*Tree<T>
}

fn test_tree() {
    left := &Tree<i32> { value = 1, left = None, right = None }
    right := &Tree<i32> { value = 3, left = None, right = None }
    root := &Tree<i32> { value = 2, left = Some(left), right = Some(right) }
    assert(root.value == 2)
    match root.left {
        Some(n) => assert(n.value == 1),
        None => assert(false),
    }
    match root.right {
        Some(n) => assert(n.value == 3),
        None => assert(false),
    }
}

// ── multiple instantiations of recursive generic ──

fn test_multiple_instantiations() {
    int_node := Node<i32> { value = 1, next = None }
    str_node := Node<str> { value = "hello", next = None }
    bool_node := Node<bool> { value = true, next = None }
    assert(int_node.value == 1)
    assert(str_node.value == "hello")
    assert(bool_node.value == true)
}
