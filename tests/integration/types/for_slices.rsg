// For loop over slices with value and index binding

// ── for over slice with value ──

fn test_for_slice_value() {
    s := []i32{10, 20, 30}
    sum := 0
    for s |v| {
        sum = sum + v
    }
    assert(sum == 60)
}

// ── for over slice with value and index ──

fn test_for_slice_value_index() {
    s := []str{"a", "b", "c"}
    count := 0
    idx_sum := 0
    for s |v, i| {
        count = count + 1
        idx_sum = idx_sum + i
    }
    assert(count == 3)
    assert(idx_sum == 3)
}

// ── for over empty slice ──

fn test_for_empty_slice() {
    s := []i32{}
    count := 0
    for s |v| {
        count = count + 1
    }
    assert(count == 0)
}

// ── for over slice index used for access ──

fn test_for_slice_index_access() {
    s := []i32{5, 10, 15, 20}
    sum := 0
    for s |v, i| {
        sum = sum + v * (i + 1)
    }
    assert(sum == 5 * 1 + 10 * 2 + 15 * 3 + 20 * 4)
}

// ── for over single element slice ──

fn test_for_single_element() {
    s := []i32{42}
    total := 0
    for s |v| {
        total = total + v
    }
    assert(total == 42)
}

// ── for over slice with break ──

fn test_for_slice_break() {
    s := []i32{1, 2, 3, 4, 5}
    sum := 0
    for s |v| {
        if v == 4 { break }
        sum = sum + v
    }
    assert(sum == 6)
}

// ── for over slice with continue ──

fn test_for_slice_continue() {
    s := []i32{1, 2, 3, 4, 5}
    sum := 0
    for s |v| {
        if v % 2 == 0 { continue }
        sum = sum + v
    }
    assert(sum == 9)
}

// ── for over sub-slice ──

fn test_for_sub_slice() {
    s := []i32{10, 20, 30, 40, 50}
    t := s[1..4]
    sum := 0
    for t |v| {
        sum = sum + v
    }
    assert(sum == 90)
}

// ── nested for over slices ──

fn test_nested_for_slices() {
    row1 := []i32{1, 2}
    row2 := []i32{3, 4}
    matrix := [][]i32{row1, row2}
    total := 0
    for matrix |row| {
        for row |v| {
            total = total + v
        }
    }
    assert(total == 10)
}
