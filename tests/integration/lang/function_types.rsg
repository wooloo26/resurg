// Function types: fn(Args) -> Return as first-class type syntax

// ── function type in variable declaration ──

fn add_one(x: i32) -> i32 {
    x + 1
}

fn test_fn_type_variable() {
    var f: fn(i32) -> i32 = add_one
    result := f(5)
    assert(result == 6, "")
}

// ── function type inferred ──

fn double(x: i32) -> i32 = x * 2

fn test_fn_type_inferred() {
    f := double
    assert(f(3) == 6, "")
}

// ── function type as parameter ──

fn apply(f: fn(i32) -> i32, x: i32) -> i32 {
    f(x)
}

fn test_fn_type_param() {
    result := apply(add_one, 10)
    assert(result == 11, "")
}

// ── function type as return type ──

fn negate(x: i32) -> i32 = 0 - x

fn choose(flag: bool) -> fn(i32) -> i32 {
    if flag { add_one } else { negate }
}

fn test_fn_type_return() {
    f := choose(true)
    assert(f(5) == 6, "")

    g := choose(false)
    assert(g(5) == -5, "")
}

// ── function type with multiple parameters ──

fn add(a: i32, b: i32) -> i32 = a + b

fn apply2(f: fn(i32, i32) -> i32, a: i32, b: i32) -> i32 {
    f(a, b)
}

fn test_fn_type_multi_param() {
    result := apply2(add, 3, 4)
    assert(result == 7, "")
}

// ── function type returning unit ──

fn do_nothing(x: i32) {
}

fn run_action(f: fn(i32)) {
    f(42)
}

fn test_fn_type_unit_return() {
    run_action(do_nothing)
}

// ── function type in type alias ──

type Predicate = fn(i32) -> bool

fn is_positive(x: i32) -> bool = x > 0

fn test_fn_type_alias() {
    var p: Predicate = is_positive
    assert(p(5) == true, "")
    assert(p(-1) == false, "")
}

// ── function type with bool parameter ──

fn bool_to_i32(b: bool) -> i32 {
    if b { 1 } else { 0 }
}

fn test_fn_type_bool_param() {
    var f: fn(bool) -> i32 = bool_to_i32
    assert(f(true) == 1, "")
    assert(f(false) == 0, "")
}
