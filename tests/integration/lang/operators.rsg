// Basic arithmetic and comparison operators

// ═══════════════════════════════════════// Arithmetic
// ═══════════════════════════════════════
fn test_addition() {
    assert(1 + 2 == 3, "")
    assert(0 + 0 == 0, "")
    assert(-5 + 5 == 0, "")
    assert(100 + 200 == 300, "")
}

fn test_subtraction() {
    assert(5 - 3 == 2, "")
    assert(0 - 0 == 0, "")
    assert(3 - 5 == -2, "")
    assert(100 - 1 == 99, "")
}

fn test_multiplication() {
    assert(3 * 4 == 12, "")
    assert(0 * 999 == 0, "")
    assert(-3 * 4 == -12, "")
    assert(-3 * -4 == 12, "")
}

fn test_division() {
    assert(10 / 2 == 5, "")
    assert(7 / 2 == 3, "") // integer division truncates
    assert(-7 / 2 == -3, "")
    assert(0 / 5 == 0, "")
}

fn test_modulo() {
    assert(10 % 3 == 1, "")
    assert(9 % 3 == 0, "")
    assert(7 % 2 == 1, "")
    assert(0 % 5 == 0, "")
}

fn test_negation() {
    x := 5
    assert(-x == -5, "")
    y := -10
    assert(-y == 10, "")
}

fn test_f64_arithmetic() {
    assert(1.5 + 2.5 == 4.0, "")
    assert(3.0 - 1.5 == 1.5, "")
    assert(2.0 * 3.5 == 7.0, "")
    assert(7.0 / 2.0 == 3.5, "")
}

// ═══════════════════════════════════════// Comparison
// ═══════════════════════════════════════
fn test_equal() {
    assert((1 == 1) == true, "")
    assert((1 == 2) == false, "")
    assert(("hello" == "hello") == true, "")
    assert(("hello" == "world") == false, "")
    assert((true == true) == true, "")
    assert((true == false) == false, "")
}

fn test_not_equal() {
    assert((1 != 2) == true, "")
    assert((1 != 1) == false, "")
    assert(("a" != "b") == true, "")
    assert(("a" != "a") == false, "")
}

fn test_less_than() {
    assert((1 < 2) == true, "")
    assert((2 < 1) == false, "")
    assert((1 < 1) == false, "")
}

fn test_less_equal() {
    assert((1 <= 2) == true, "")
    assert((2 <= 2) == true, "")
    assert((3 <= 2) == false, "")
}

fn test_greater_than() {
    assert((2 > 1) == true, "")
    assert((1 > 2) == false, "")
    assert((1 > 1) == false, "")
}

fn test_greater_equal() {
    assert((2 >= 1) == true, "")
    assert((2 >= 2) == true, "")
    assert((1 >= 2) == false, "")
}

// ═══════════════════════════════════════// Logical
// ═══════════════════════════════════════
fn test_logical_and() {
    assert((true && true) == true, "")
    assert((true && false) == false, "")
    assert((false && true) == false, "")
    assert((false && false) == false, "")
}

fn test_logical_or() {
    assert((true || true) == true, "")
    assert((true || false) == true, "")
    assert((false || true) == true, "")
    assert((false || false) == false, "")
}

fn test_logical_not() {
    assert(!true == false, "")
    assert(!false == true, "")
}

// ═══════════════════════════════════════// Compound assignment
// ═══════════════════════════════════════
fn test_compound_assignment() {
    x := 10
    x += 5
    assert(x == 15, "")
    x -= 3
    assert(x == 12, "")
    x *= 2
    assert(x == 24, "")
    x /= 4
    assert(x == 6, "")
}

fn test_f64_compound_assignment() {
    x := 10.0
    x += 2.5
    assert(x == 12.5, "")
    x -= 1.5
    assert(x == 11.0, "")
    x *= 2.0
    assert(x == 22.0, "")
    x /= 4.0
    assert(x == 5.5, "")
}

// ═══════════════════════════════════════// f64 Comparison
// ═══════════════════════════════════════
fn test_f64_equal() {
    assert((1.0 == 1.0) == true, "")
    assert((1.0 == 2.0) == false, "")
    assert((0.0 == 0.0) == true, "")
}

fn test_f64_not_equal() {
    assert((1.5 != 2.5) == true, "")
    assert((3.14 != 3.14) == false, "")
}

fn test_f64_less_than() {
    assert((1.0 < 2.0) == true, "")
    assert((2.0 < 1.0) == false, "")
    assert((1.0 < 1.0) == false, "")
}

fn test_f64_less_equal() {
    assert((1.0 <= 2.0) == true, "")
    assert((2.0 <= 2.0) == true, "")
    assert((3.0 <= 2.0) == false, "")
}

fn test_f64_greater_than() {
    assert((2.0 > 1.0) == true, "")
    assert((1.0 > 2.0) == false, "")
    assert((1.0 > 1.0) == false, "")
}

fn test_f64_greater_equal() {
    assert((2.0 >= 1.0) == true, "")
    assert((2.0 >= 2.0) == true, "")
    assert((1.0 >= 2.0) == false, "")
}

// ═══════════════════════════════════════// Precedence
// ═══════════════════════════════════════
fn test_precedence() {
    // multiplication before addition
    assert(2 + 3 * 4 == 14, "") // parentheses override precedence
    assert((2 + 3) * 4 == 20, "") // division before subtraction
    assert(10 - 4 / 2 == 8, "") // mixed
    assert(2 * 3 + 4 * 5 == 26, "") // comparison lower than arithmetic
    assert((3 + 4 > 6) == true, "") // logical lower than comparison
    assert((1 < 2 && 3 < 4) == true, "")
    assert((1 > 2 || 3 < 4) == true, "")
}

fn test_and_or_precedence() {
    // && binds tighter than ||
    assert((true || false && false) == true, "") // true || (false && false) => true
    assert((false || true && true) == true, "") // false || (true && true) => true
    assert((false || false && true) == false, "") // false || (false && true) => false
}

fn test_negation_expressions() {
    a := 3
    b := 5
    assert(-(a + b) == -8, "")
    assert(-(a * b) == -15, "")
    assert(-(-a) == 3, "")
}

fn test_u32_arithmetic() {
    var a: u32 = 100
    var b: u32 = 30
    assert(a + b == 130, "")
    assert(a - b == 70, "")
    assert(a * b == 3000, "")
    assert(a / b == 3, "")
    assert(a % b == 10, "")
}

fn test_u32_comparison() {
    var a: u32 = 10
    var b: u32 = 20
    assert((a < b) == true, "")
    assert((a > b) == false, "")
    assert((a <= b) == true, "")
    assert((a >= b) == false, "")
    assert((a == b) == false, "")
    assert((a != b) == true, "")
}
