// panic and catch_panic: structured panic/catch control flow
// EXPECT-STDOUT: About to panic...
// EXPECT-STDOUT: Caught panic: went wrong
// EXPECT-STDOUT: safe_call returned: went wrong
// EXPECT-STDOUT: after safe_call
// EXPECT-STDOUT: no panic happened
// EXPECT-STDOUT: nested: inner panic
// EXPECT-STDOUT: multiple defers work

// ── panic caught via catch_panic ──

fn safe_call() -> str!str {
    catch_panic(|| -> str {
        println("About to panic...")
        panic("went wrong")
    })
}

fn test_panic_catch_basic() {
    result := safe_call()
    match result {
        Ok(_) => assert(false, ""),
        Err(msg) => {
            println("Caught panic: {msg}")
            println("safe_call returned: {msg}")
        },
    }
    println("after safe_call")
}

// ── catch_panic returns Ok when no panic ──

fn test_catch_no_panic() {
    result := catch_panic(|| -> i32 { 42 })
    match result {
        Ok(v) => {
            assert(v == 42, "")
            println("no panic happened")
        },
        Err(_) => assert(false, ""),
    }
}

// ── nested function panic propagates up ──

fn inner_panic() -> str {
    panic("inner panic")
}

fn test_nested_panic() {
    result := catch_panic(inner_panic)
    match result {
        Ok(_) => assert(false, ""),
        Err(msg) => println("nested: {msg}"),
    }
}

// ── multiple defers still run when not related to catch_panic ──

fn multiple_defers_fn() {
    defer {
        println("multiple defers work")
    }

    // No panic here — just verify defer runs
}

fn test_multiple_defers() {
    multiple_defers_fn()
}
