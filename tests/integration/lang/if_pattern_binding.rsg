// if pattern binding: if Some(x) := expr { ... }

// ── if-let with Some ──

fn find_value(key: str) -> ?i32 {
    if key == "x" { Some(42) }
    else { None }
}

fn test_if_let_some() {
    found := false
    if Some(v) := find_value("x") {
        assert(v == 42, "")
        found = true
    }
    assert(found == true, "")
}

fn test_if_let_none() {
    found := false
    missed := false
    if Some(v) := find_value("y") {
        found = true
    } else {
        missed = true
    }
    assert(found == false, "")
    assert(missed == true, "")
}

// ── if-let with Ok/Err ──

fn parse_integer(s: str) -> i32 ! str {
    if s == "42" { Ok(42) }
    else { Err("parse error") }
}

fn test_if_let_ok() {
    found := false
    if Ok(value) := parse_integer("42") {
        assert(value == 42, "")
        found = true
    }
    assert(found == true, "")
}

fn test_if_let_ok_miss() {
    found := false
    missed := false
    if Ok(value) := parse_integer("abc") {
        found = true
    } else {
        missed = true
    }
    assert(found == false, "")
    assert(missed == true, "")
}

// ── if-let used as expression guard ──

fn test_if_let_guard() {
    result := find_value("x")
    found := false
    if Some(v) := result {
        assert(v == 42, "")
        found = true
    }
    assert(found == true, "")
}

fn test_if_let_guard_miss() {
    result := find_value("z")
    found := false
    if Some(_) := result {
        found = true
    }
    assert(found == false, "")
}
