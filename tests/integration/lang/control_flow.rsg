// if/else expressions, loop/break/continue, for with range

// ═══════════════════════════════════════// if / else expressions
// ═══════════════════════════════════════
fn test_if_basic() {
    x := 10
    result := if x > 5 { "big" } else { "small" }
    assert(result == "big", "")
}

fn test_if_else_chain() {
    x := 0
    label := if x > 0 {
        "positive"
    } else if x < 0 {
        "negative"
    } else {
        "zero"
    }
    assert(label == "zero", "")
}

fn test_if_as_expression() {
    a := 3
    b := 7
    max := if a > b { a } else { b }
    assert(max == 7, "")
    min := if a < b { a } else { b }
    assert(min == 3, "")
}

fn test_if_nested() {
    x := 15
    result := if x > 10 {
        if x > 20 { "very big" } else { "big" }
    } else {
        "small"
    }
    assert(result == "big", "")
}

fn test_if_bool_condition() {
    flag := true
    val := if flag { 1 } else { 0 }
    assert(val == 1, "")
    flag = false
    val = if flag { 1 } else { 0 }
    assert(val == 0, "")
}

// ═══════════════════════════════════════// loop / break / continue
// ═══════════════════════════════════════
fn test_loop_break() {
    count := 0
    loop {
        count = count + 1
        if count == 5 { break }
    }
    assert(count == 5, "")
}

fn test_loop_continue() {
    sum := 0
    i := 0
    loop {
        i = i + 1
        if i > 10 { break }
        if i % 2 != 0 { continue }
        // only even numbers reach here
        sum = sum + i
    }
    // 2 + 4 + 6 + 8 + 10 = 30
    assert(sum == 30, "")
}

fn test_loop_immediate_break() {
    executed := false
    loop {
        executed = true
        break
    }
    assert(executed == true, "")
}

fn test_loop_counter() {
    // count to 100
    n := 0
    loop {
        if n >= 100 { break }
        n = n + 1
    }
    assert(n == 100, "")
}

fn test_nested_loops() {
    count := 0
    i := 0
    loop {
        if i >= 3 { break }
        j := 0
        loop {
            if j >= 4 { break }
            count = count + 1
            j = j + 1
        }
        i = i + 1
    }
    assert(count == 12, "") // 3 * 4
}

// ═══════════════════════════════════════// for with range (0..N)
// ═══════════════════════════════════════
fn test_for_range_basic() {
    sum := 0
    for 0..5 |i| {
        sum = sum + i
    }
    // 0 + 1 + 2 + 3 + 4 = 10
    assert(sum == 10, "")
}

fn test_for_range_start_end() {
    sum := 0
    for 3..7 |i| {
        sum = sum + i
    }
    // 3 + 4 + 5 + 6 = 18
    assert(sum == 18, "")
}

fn test_for_range_single() {
    count := 0
    for 0..1 |i| {
        count = count + 1
    }
    assert(count == 1, "")
}

fn test_for_range_empty() {
    count := 0
    for 5..5 |i| {
        count = count + 1
    }
    assert(count == 0, "")
}

fn test_for_range_accumulate() {
    // compute factorial of 5 using a for loop
    result := 1
    for 1..6 |i| {
        result = result * i
    }
    // 1 * 2 * 3 * 4 * 5 = 120
    assert(result == 120, "")
}

fn test_for_range_nested() {
    sum := 0
    for 0..3 |i| {
        for 0..3 |j| {
            sum = sum + 1
        }
    }
    assert(sum == 9, "")
}

// ═══════════════════════════════════════// if without else (statement form)
// ═══════════════════════════════════════
fn test_if_without_else() {
    x := 0
    if true {
        x = 42
    }
    assert(x == 42, "")
    y := 10
    if false {
        y = 99
    }
    assert(y == 10, "")
}

fn test_if_side_effect_only() {
    count := 0
    for 0..5 |i| {
        if i % 2 == 0 {
            count = count + 1
        }
    }
    // 0, 2, 4 are even
    assert(count == 3, "")
}

// ═══════════════════════════════════════// continue inside for-range loop
// ═══════════════════════════════════════
fn test_for_continue() {
    sum := 0
    for 0..10 |i| {
        if i % 2 != 0 { continue }
        sum = sum + i
    }
    // 0 + 2 + 4 + 6 + 8 = 20
    assert(sum == 20, "")
}

fn test_for_continue_skip_first() {
    sum := 0
    for 0..5 |i| {
        if i == 0 { continue }
        sum = sum + i
    }
    // 1 + 2 + 3 + 4 = 10
    assert(sum == 10, "")
}

// ═══════════════════════════════════════// for with variable bounds
// ═══════════════════════════════════════
fn test_for_variable_bounds() {
    start := 2
    end := 6
    sum := 0
    for start..end |i| {
        sum = sum + i
    }
    // 2 + 3 + 4 + 5 = 14
    assert(sum == 14, "")
}

fn test_for_computed_bounds() {
    n := 5
    sum := 0
    for 0..n * 2 |i| {
        sum = sum + 1
    }
    assert(sum == 10, "")
}

// ═══════════════════════════════════════// break only breaks inner loop
// ═══════════════════════════════════════
fn test_break_inner_loop_only() {
    outer_count := 0
    inner_total := 0
    for 0..3 |i| {
        outer_count = outer_count + 1
        j := 0
        loop {
            if j >= 2 { break }
            inner_total = inner_total + 1
            j = j + 1
        }
    }
    assert(outer_count == 3, "")
    assert(inner_total == 6, "") // 3 * 2
}

// ═══════════════════════════════════════// if/else expression in for loop
// ═══════════════════════════════════════
fn test_if_else_in_for() {
    sum := 0
    for 1..6 |i| {
        val := if i % 2 == 0 { i } else { 0 }
        sum = sum + val
    }
    // only even: 2 + 4 = 6
    assert(sum == 6, "")
}
