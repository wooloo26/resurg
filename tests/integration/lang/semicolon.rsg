// Semicolon as statement separator

// ── two statements separated by semicolon ──

fn test_basic_semicolon() {
    a := 1; b := 2
    assert(a == 1, "")
    assert(b == 2, "")
}

// ── multiple statements on one line ──

fn test_multiple_semicolons() {
    a := 10; b := 20; c := 30
    assert(a + b + c == 60, "")
}

// ── semicolon in function body (methods via ext block) ──

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0
}

ext Point {
    fn reset(mut *p) { p.x = 0.0; p.y = 0.0 }
}

fn test_semicolon_in_method() {
    p := &Point { x = 5.0, y = 10.0 }
    p.reset()
    assert(p.x == 0.0, "")
    assert(p.y == 0.0, "")
}

// ── semicolon with assignment ──

fn test_semicolon_assignment() {
    var x: i32 = 0; var y: i32 = 0
    x = 5; y = 10
    assert(x == 5, "")
    assert(y == 10, "")
}

// ── semicolon with function calls ──

fn inc(n: i32) -> i32 = n + 1
fn double(n: i32) -> i32 = n * 2

fn test_semicolon_with_calls() {
    a := inc(1); b := double(3)
    assert(a == 2, "")
    assert(b == 6, "")
}

// ── semicolons inside if/else blocks ──

fn test_semicolon_in_if_block() {
    x := 10
    if x > 5 {
        a := x + 1; b := x + 2
        assert(a == 11, ""); assert(b == 12, "")
    }
}

// ── semicolons inside loop ──

fn test_semicolon_in_loop() {
    var count: i32 = 0; var sum: i32 = 0
    loop {
        count = count + 1; sum = sum + count
        if count == 3 { break }
    }
    assert(count == 3, "")
    assert(sum == 6, "")
}

// ── trailing semicolon is allowed ──

fn test_trailing_semicolon() {
    a := 1;
    b := 2;
    assert(a + b == 3, "")
}
