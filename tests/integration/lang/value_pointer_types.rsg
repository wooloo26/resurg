// Clarify value types and pointer types

// Value types: Primitives, str, [N]T, tuples, structs, enums, ?T, T!E — Copied
// Pointer types: *T (pointer via &), fn — Shared

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0
}

enum Color { Red, Green, Blue }

// ── primitive value copy ──

fn test_primitive_value_copy() {
    a := 42
    b := a
    b = 99
    assert(a == 42)
    assert(b == 99)
}

// ── str value copy ──

fn test_str_value_copy() {
    a := "hello"
    b := a
    b = "world"
    assert(a == "hello")
    assert(b == "world")
}

// ── array value copy ──

fn test_array_value_copy() {
    a := [3]i32{1, 2, 3}
    b := a
    b[0] = 99
    assert(a[0] == 1)
    assert(b[0] == 99)
}

// ── tuple value copy ──

fn test_tuple_value_copy() {
    a := (1, "two")
    b := a
    assert(b.0 == 1)
    assert(b.1 == "two")
}

// ── struct value copy ──

fn test_struct_value_copy() {
    a := Point { x = 1.0, y = 2.0 }
    b := a
    b.x = 99.0
    assert(a.x == 1.0)
    assert(b.x == 99.0)
}

// ── enum value copy ──

fn test_enum_value_copy() {
    a := Color::Red
    b := a
    assert(true)
}

// ── option value copy ──

fn test_option_value_copy() {
    a := Some(42)
    b := a
    assert(true)
}

// ── result value copy ──

fn divide(a: f64, b: f64) -> f64 ! str {
    if b == 0.0 { Err("div by zero") }
    else { Ok(a / b) }
}

fn test_result_value_copy() {
    a := divide(10.0, 2.0)
    b := a
    assert(true)
}

// ── pointer copy: aliases share same object ──

fn test_pointer_copy_shared() {
    a := &Point { x = 1.0, y = 2.0 }
    b := a
    b.x = 99.0
    assert(a.x == 99.0)
}

// ── fn is pointer type (shared) ──

fn add(a: i32, b: i32) -> i32 = a + b

fn test_fn_pointer_type() {
    f := add
    g := f
    assert(g(1, 2) == 3)
    assert(f(1, 2) == 3)
}

// ── value param receives independent copy ──

fn shift(p: Point, dx: f64) -> Point {
    p.x = p.x + dx
    p
}

fn test_value_param_copy() {
    origin := Point { x = 0.0, y = 0.0 }
    moved := shift(origin, 5.0)
    assert(origin.x == 0.0)
    assert(moved.x == 5.0)
}

// ── pointer param shares state ──

fn shift_mut(mut p: *Point, dx: f64) {
    p.x = p.x + dx
}

fn test_pointer_param_shared() {
    origin := Point { x = 0.0, y = 0.0 }
    shift_mut(mut &origin, 5.0)
    assert(origin.x == 5.0)
}
