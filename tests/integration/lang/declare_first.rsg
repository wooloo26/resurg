// Decl first: variable declaration without initializer

// ── simple decl then assign ──

fn test_declare_first_simple() {
    var x: i32
    x = 42
    assert(x == 42, "")
}

// ── decl first with conditional assignment ──

fn test_declare_first_conditional() {
    var result: str
    if true {
        result = "yes"
    } else {
        result = "no"
    }
    assert(result == "yes", "")
}

fn test_declare_first_conditional_else() {
    var result: str
    if false {
        result = "yes"
    } else {
        result = "no"
    }
    assert(result == "no", "")
}

// ── decl first then use in loop ──

fn test_declare_first_loop() {
    var total: i32
    total = 0
    for 0..5 |i| {
        total = total + i
    }
    assert(total == 10, "")
}
