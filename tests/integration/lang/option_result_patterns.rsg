// Option/Result pattern matching: Some(v), Ok(v), Err(e)

// ── match on option with wildcard ──

fn test_option_wildcard() {
    var x: ?i32 = Some(10)
    result := match x {
        Some(_) => "has value",
        None => "empty",
    }
    assert(result == "has value")
}

// ── match on option with binding ──

fn test_option_binding() {
    var x: ?i32 = Some(7)
    result := match x {
        Some(v) => v * 2,
        None => 0,
    }
    assert(result == 14)
}

// ── match on result with Ok and Err ──

fn test_result_ok_binding() {
    var x: i32 ! str = Ok(99)
    result := match x {
        Ok(v) => v + 1,
        Err(_) => -1,
    }
    assert(result == 100)
}

fn test_result_err_binding() {
    var x: i32 ! str = Err("fail")
    result := match x {
        Ok(_) => "",
        Err(e) => e,
    }
    assert(result == "fail")
}

// ── match guard on option ──

fn test_option_match_guard() {
    var x: ?i32 = Some(42)
    result := match x {
        Some(v) if v > 100 => "big",
        Some(v) if v > 10 => "medium",
        Some(_) => "small",
        None => "none",
    }
    assert(result == "medium")
}

// ── match guard on result ──

fn test_result_match_guard() {
    var x: i32 ! str = Ok(5)
    result := match x {
        Ok(v) if v > 10 => "big",
        Ok(v) if v > 0 => "positive",
        Ok(_) => "zero or negative",
        Err(_) => "error",
    }
    assert(result == "positive")
}

// ── exhaustive match required ──

fn test_exhaustive_option() {
    var x: ?str = None
    result := match x {
        Some(s) => s,
        None => "default",
    }
    assert(result == "default")
}

fn test_exhaustive_result() {
    var x: bool ! str = Err("oops")
    result := match x {
        Ok(v) => v,
        Err(_) => false,
    }
    assert(result == false)
}
