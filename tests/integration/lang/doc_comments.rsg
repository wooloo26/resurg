// Documentation Comments: /// syntax with @param, @return, code blocks

// ── doc comment on function ──

/// Adds two integers.
fn add(a: i32, b: i32) -> i32 { a + b }

fn test_doc_comment_fn() {
    assert(add(1, 2) == 3)
}

// ── multi-line doc comment with @param and @return ──

/// Computes the GCD using the Euclidean algorithm.
///
/// @param a  First non-negative integer.
/// @param b  Second non-negative integer.
/// @return   The GCD of `a` and `b`.
fn gcd(a: i32, b: i32) -> i32 {
    if b == 0 { a } else { gcd(b, a % b) }
}

fn test_doc_comment_multiline_fn() {
    assert(gcd(12, 8) == 4)
    assert(gcd(7, 1) == 1)
    assert(gcd(100, 25) == 25)
}

// ── doc comment on struct ──

/// A 2D point in Cartesian space.
struct Point {
    /// Horizontal coordinate.
    x: f64 = 0.0
    /// Vertical coordinate.
    y: f64 = 0.0
}

fn test_doc_comment_struct() {
    p := Point { x = 1.0, y = 2.0 }
    assert(p.x == 1.0)
    assert(p.y == 2.0)
}

// ── doc comment on extension method ──

/// Point utilities.
ext Point {
    /// Computes the sum of coordinates.
    fn sum(p) -> f64 { p.x + p.y }
}

fn test_doc_comment_ext() {
    p := Point { x = 3.0, y = 4.0 }
    assert(p.sum() == 7.0)
}

// ── doc comment on enum ──

/// Represents a shape.
enum Shape {
    /// A circle with a radius.
    Circle(f64),
    /// A rectangle with width and height.
    Rect { w: f64, h: f64 },
}

fn test_doc_comment_enum() {
    c := Shape::Circle(5.0)
    match c {
        Circle(r) => assert(r == 5.0),
        _ => assert(false),
    }
}

// ── doc comment on pact ──

/// A displayable type.
pact Describable {
    /// Returns a description string.
    fn describe(*self) -> str
}

struct Widget {
    name: str
}

ext Widget impl Describable {
    /// Returns the widget name as a description.
    fn describe(*w) -> str { w.name }
}

fn test_doc_comment_pact() {
    w := Widget { name = "button" }
    assert(w.describe() == "button")
}

// ── doc comment on type alias ──

/// A handler function type.
type Handler = fn(i32) -> bool

fn test_doc_comment_type_alias() {
    var h: Handler = |x| x > 0
    assert(h(1) == true)
    assert(h(-1) == false)
}

// ── doc comment with code block ──

/// Doubles a value.
///
/// Example:
/// ```
/// result := double(5)
/// assert(result == 10)
/// ```
fn double(x: i32) -> i32 { x * 2 }

fn test_doc_comment_code_block() {
    assert(double(5) == 10)
}

// ── doc comment before variable (local) ──

fn test_doc_comment_variable() {
    /// The maximum value.
    max_val := 100
    assert(max_val == 100)
}

// ── multiple consecutive doc comment lines ──

/// Line one.
/// Line two.
/// Line three.
fn triple(x: i32) -> i32 { x * 3 }

fn test_doc_comment_multi_consecutive() {
    assert(triple(4) == 12)
}

// ── doc comment with special characters ──

/// Returns `true` if `n` is even.
/// Uses the modulo (`%`) operator.
fn is_even(n: i32) -> bool { n % 2 == 0 }

fn test_doc_comment_special_chars() {
    assert(is_even(4) == true)
    assert(is_even(3) == false)
}
