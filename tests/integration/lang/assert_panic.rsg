// assert rewritten on top of panic: assert failures are now catchable
// EXPECT-STDOUT: caught assert: assertion failed
// EXPECT-STDOUT: caught assert with msg: x must be positive
// EXPECT-STDOUT: assert passes normally

// ── assert(false, "assertion failed") triggers panic, catchable via catch_panic ──

fn test_assert_panics_on_failure() {
    result := catch_panic(|| -> i32 {
        assert(false, "assertion failed")
        0
    })
    match result {
        Ok(_) => assert(true, ""),
        Err(msg) => println("caught assert: {msg}"),
    }
}

// ── assert(false, "message") includes custom message ──

fn test_assert_panics_with_message() {
    result := catch_panic(|| -> i32 {
        assert(false, "x must be positive")
        0
    })
    match result {
        Ok(_) => assert(true, ""),
        Err(msg) => println("caught assert with msg: {msg}"),
    }
}

// ── assert(true, "") does not panic ──

fn test_assert_passes() {
    assert(true, "")
    assert(1 + 1 == 2, "")
    assert(1 + 1 == 2, "basic math")
    println("assert passes normally")
}
