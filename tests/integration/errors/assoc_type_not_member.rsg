// TEST: compile_error
// EXPECT-ERROR: associated type
// v0.9.4 — Error: defining an associated type that is not a member of the pact

pact Iterator {
    type Item
    fn next(mut *self) -> ?Self::Item
}

struct BadIter: Iterator {
    type Item = i32
    type Alias = str

    fn next(mut *self) -> ?i32 {
        None
    }
}

fn main() {
    iter := BadIter {}
}
