// v0.3.0 — Named arguments at call site
module test_named_args

fn add(a: i32, b: i32) -> i32 {
    a + b
}

fn greet(name: str, greeting: str) -> str {
    "{greeting}, {name}!"
}

// ── all args named, in order ──
fn test_named_basic() {
    result := add(a = 1, b = 2)
    assert(result == 3)
}

// ── named args in different order ──
fn test_named_reorder() {
    result := add(b = 10, a = 5)
    assert(result == 15)
}

// ── named with string args ──
fn test_named_strings() {
    msg := greet(name = "Alice", greeting = "Hello")
    assert(msg == "Hello, Alice!")
}

// ── named reorder with string args ──
fn test_named_strings_reorder() {
    msg := greet(greeting = "Hi", name = "Bob")
    assert(msg == "Hi, Bob!")
}

// ── named args on method calls ──
struct Calculator {
    result: i32 = 0

    fn add_values(mut *c, x: i32, y: i32) {
        c.result = x + y
    }
}

fn test_named_on_method() {
    c := Calculator {}
    c.add_values(x = 10, y = 20)
    assert(c.result == 30)
}

fn test_named_on_method_reorder() {
    c := Calculator {}
    c.add_values(y = 20, x = 10)
    assert(c.result == 30)
}

// ── named args with expression values ──
fn test_named_expressions() {
    x := 5
    result := add(a = x * 2, b = x + 1)
    assert(result == 16)
}
