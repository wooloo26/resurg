// v0.9.6 — Enums contain only variants; methods move to ext blocks

// ── enum with unit, tuple, struct variants ──

enum Message {
    Quit,
    Write(str),
    Move { x: i32, y: i32 },
}

ext Message {
    fn describe(*m) -> str {
        match m {
            Quit => "quit",
            Write(text) => text,
            Move { x, y } => "move",
        }
    }
}

fn test_enum_methods_in_ext() {
    q := Message::Quit
    assert(q.describe() == "quit")

    w := Message::Write("hello")
    assert(w.describe() == "hello")

    m := Message::Move { x = 1, y = 2 }
    assert(m.describe() == "move")
}

// ── enum with explicit discriminants ──

enum Status {
    Active = 1,
    Inactive = 0,
    Pending = 2,
}

fn test_enum_discriminants() {
    s := Status::Active
    assert(true)
}

// ── enum with mut pointer receiver in ext ──

enum Toggle {
    On,
    Off,
}

ext Toggle {
    fn is_on(*t) -> bool {
        match t {
            On => true,
            Off => false,
        }
    }

    fn flip(mut *t) {
        match t {
            On => { t = Toggle::Off },
            Off => { t = Toggle::On },
        }
    }
}

fn test_enum_mut_ext() {
    t := Toggle::On
    assert(t.is_on())
    t.flip()
    assert(t.is_on() == false)
    t.flip()
    assert(t.is_on())
}
