// v0.5.2 — Escape Analysis: if not proven non-escaping, it escapes

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0
}

struct Container {
    value: i32 = 0
}

// ── non-escaping: local address-of for read ──

fn test_local_read() {
    x := 42
    px := &x
    assert(*px == 42)
}

// ── non-escaping: local address-of for write ──

fn test_local_write() {
    x := 10
    px := &x
    *px = 20
    assert(x == 20)
    assert(*px == 20)
}

// ── non-escaping: address-of struct variable ──

fn test_local_struct_read() {
    p := Point { x = 3.0, y = 4.0 }
    pp := &p
    assert(pp.x == 3.0)
    assert(pp.y == 4.0)
}

// ── non-escaping: mut &x passed to function ──

fn set_int(mut p: *i32, val: i32) {
    *p = val
}

fn test_mut_arg_non_escaping() {
    x := 0
    set_int(mut &x, 42)
    assert(x == 42)
}

// ── non-escaping: mut &struct passed to function ──

fn set_point_x(mut p: *Point, val: f64) {
    p.x = val
}

fn test_mut_struct_arg_non_escaping() {
    p := Point { x = 0.0, y = 2.0 }
    set_point_x(mut &p, 10.0)
    assert(p.x == 10.0)
    assert(p.y == 2.0)
}

// ── non-escaping: address-of in loop body ──

fn test_address_of_in_loop() {
    for 0..5 |i| {
        val := i * 10
        pv := &val
        assert(*pv == i * 10)
    }
}

// ── escaping: return &primitive from function ──

fn make_int_ptr(v: i32) -> *i32 {
    x := v
    &x
}

fn test_escape_return_primitive() {
    p := make_int_ptr(42)
    assert(*p == 42)
}

// ── escaping: return &struct from function ──

fn make_point_ptr(x: f64, y: f64) -> *Point {
    p := Point { x = x, y = y }
    &p
}

fn test_escape_return_struct() {
    p := make_point_ptr(5.0, 6.0)
    assert(p.x == 5.0)
    assert(p.y == 6.0)
}

// ── escaping: indirect return via variable binding ──

fn indirect_escape(v: i32) -> *i32 {
    x := v
    ptr := &x
    ptr
}

fn test_escape_indirect() {
    p := indirect_escape(77)
    assert(*p == 77)
}

// ── escaping: return address-of parameter ──

fn param_escape(v: i32) -> *i32 {
    &v
}

fn test_escape_param() {
    p := param_escape(55)
    assert(*p == 55)
}

// ── escaping: returned pointer survives GC pressure ──

fn test_escape_gc_survival() {
    p := make_int_ptr(42)
    for 0..500 |i| {
        tmp := make_int_ptr(i)
    }
    assert(*p == 42)
}

// ── escaping: multiple returned pointers are independent ──

fn test_escape_independence() {
    a := make_int_ptr(10)
    b := make_int_ptr(20)
    assert(*a == 10)
    assert(*b == 20)
}

// ── escaping: returned struct pointer retains field values ──

fn test_escape_struct_fields() {
    p := make_point_ptr(7.0, 8.0)
    for 0..500 |i| {
        tmp := make_point_ptr(0.0, 0.0)
    }
    assert(p.x == 7.0)
    assert(p.y == 8.0)
}

// ── non-escaping: coexists with heap alloc in same function ──

fn test_mixed_local_and_heap() {
    x := 42
    px := &x
    *px = 100
    assert(x == 100)

    p := &Point { x = 3.0, y = 4.0 }
    assert(p.x == 3.0)
}

// ── escaping: nested function returns escaped pointer ──

fn make_container_ptr(v: i32) -> *Container {
    c := Container { value = v }
    &c
}

fn test_escape_nested_calls() {
    a := make_container_ptr(100)
    b := make_container_ptr(200)
    assert(a.value == 100)
    assert(b.value == 200)
}

// ── escaping: address-of in conditional branch ──

fn conditional_escape(flag: bool, a: i32, b: i32) -> *i32 {
    if flag {
        x := a
        &x
    } else {
        y := b
        &y
    }
}

fn test_escape_conditional() {
    p1 := conditional_escape(true, 10, 20)
    p2 := conditional_escape(false, 10, 20)
    assert(*p1 == 10)
    assert(*p2 == 20)
}
