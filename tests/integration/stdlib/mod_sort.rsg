// stdlib: Phase 4 — sort module (generic pact-bounded)
// EXPECT-STDOUT: sort module tests passed
mod sort

use self::sort::sort
use self::sort::is_sorted
use self::sort::binary_search

fn main() {
    arr := []i32{5, 3, 1, 4, 2}
    sort(mut &arr)
    assert(arr[0] == 1, "sort first")
    assert(arr[1] == 2, "sort second")
    assert(arr[2] == 3, "sort third")
    assert(arr[3] == 4, "sort fourth")
    assert(arr[4] == 5, "sort fifth")
    assert(is_sorted(arr), "is_sorted after sort")

    idx := binary_search(arr, 3)
    assert(idx == 2, "binary_search found")
    idx2 := binary_search(arr, 99)
    assert(idx2 == -1, "binary_search not found")

    println("sort module tests passed")
}
