// stdlib: #[extern("symbol")] attribute — custom C symbol binding
// EXPECT-STDOUT: extern attr tests passed

ext str {
    // Without #[extern], this would try to call rsg_str_has (undefined).
    // With #[extern], compiler prepends rsg_ → rsg_str_contains.
    #[extern("str_contains")]
    pub decl fn has(s, needle: str) -> bool
}

fn main() {
    assert("hello world".has("world"), "extern alias has=contains match")
    assert(!"hello".has("xyz"), "extern alias has=contains no match")
    assert("abc".has(""), "extern alias has=contains empty needle")
    println("extern attr tests passed")
}
