// v0.6.0 — Slice type []T: declaration, literals, indexing, length

// ── slice literal ──

fn test_slice_literal() {
    s := []i32{1, 2, 3, 4, 5}
    assert(len(s) == 5)
    assert(s[0] == 1)
    assert(s[1] == 2)
    assert(s[2] == 3)
    assert(s[3] == 4)
    assert(s[4] == 5)
}

// ── empty slice ──

fn test_empty_slice() {
    s := []i32{}
    assert(len(s) == 0)
}

// ── typed declaration ──

fn test_slice_typed_declaration() {
    var s: []i32 = []i32{10, 20, 30}
    assert(len(s) == 3)
    assert(s[0] == 10)
    assert(s[2] == 30)
}

// ── slice of booleans ──

fn test_slice_bool() {
    s := []bool{true, false, true}
    assert(len(s) == 3)
    assert(s[0] == true)
    assert(s[1] == false)
    assert(s[2] == true)
}

// ── slice of strings ──

fn test_slice_str() {
    s := []str{"hello", "world"}
    assert(len(s) == 2)
    assert(s[0] == "hello")
    assert(s[1] == "world")
}

// ── slice of f64 ──

fn test_slice_f64() {
    s := []f64{1.5, 2.5, 3.5}
    assert(len(s) == 3)
    assert(s[0] == 1.5)
    assert(s[2] == 3.5)
}

// ── slice element mutation ──

fn test_slice_mutation() {
    s := []i32{1, 2, 3}
    s[0] = 99
    assert(s[0] == 99)
    assert(s[1] == 2)
    assert(s[2] == 3)
}

// ── slice passed to function ──

fn sum_slice(s: []i32) -> i32 {
    total := 0
    for 0..len(s) |i| {
        total = total + s[i]
    }
    total
}

fn test_slice_pass_to_function() {
    s := []i32{10, 20, 30}
    assert(sum_slice(s) == 60)
}

// ── single element slice ──

fn test_single_element_slice() {
    s := []i32{42}
    assert(len(s) == 1)
    assert(s[0] == 42)
}
