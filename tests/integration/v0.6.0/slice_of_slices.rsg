// v0.6.0 — Slice of slices [][]T
module test_slice_of_slices

// ── basic slice of slices ──

fn test_slice_of_slices_basic() {
    row1 := []i32[1, 2, 3]
    row2 := []i32[4, 5, 6]
    matrix := [][]i32[row1, row2]
    assert(matrix.len == 2)
    assert(matrix[0].len == 3)
    assert(matrix[1].len == 3)
    assert(matrix[0][0] == 1)
    assert(matrix[0][2] == 3)
    assert(matrix[1][0] == 4)
    assert(matrix[1][2] == 6)
}

// ── empty slice of slices ──

fn test_empty_slice_of_slices() {
    matrix := [][]i32[]
    assert(matrix.len == 0)
}

// ── slice of slices with different lengths ──

fn test_jagged_slices() {
    a := []i32[1]
    b := []i32[2, 3]
    c := []i32[4, 5, 6]
    jagged := [][]i32[a, b, c]
    assert(jagged.len == 3)
    assert(jagged[0].len == 1)
    assert(jagged[1].len == 2)
    assert(jagged[2].len == 3)
    assert(jagged[0][0] == 1)
    assert(jagged[1][1] == 3)
    assert(jagged[2][2] == 6)
}

// ── mutation in inner slice ──

fn test_inner_slice_mutation() {
    row1 := []i32[10, 20]
    row2 := []i32[30, 40]
    matrix := [][]i32[row1, row2]
    matrix[0][1] = 99
    assert(row1[1] == 99)
}
