// v0.6.0 — Sub-slicing: s[1..4], s[2..], s[..3]

// ── sub-slice with both bounds ──

fn test_sub_slice_both_bounds() {
    s := []i32{1, 2, 3, 4, 5}
    t := s[1..4]
    assert(len(t) == 3)
    assert(t[0] == 2)
    assert(t[1] == 3)
    assert(t[2] == 4)
}

// ── sub-slice open end ──

fn test_sub_slice_open_end() {
    s := []i32{1, 2, 3, 4, 5}
    t := s[2..]
    assert(len(t) == 3)
    assert(t[0] == 3)
    assert(t[1] == 4)
    assert(t[2] == 5)
}

// ── sub-slice open start ──

fn test_sub_slice_open_start() {
    s := []i32{1, 2, 3, 4, 5}
    t := s[..3]
    assert(len(t) == 3)
    assert(t[0] == 1)
    assert(t[1] == 2)
    assert(t[2] == 3)
}

// ── sub-slice full range ──

fn test_sub_slice_full_range() {
    s := []i32{1, 2, 3, 4, 5}
    t := s[0..5]
    assert(len(t) == 5)
    assert(t[0] == 1)
    assert(t[4] == 5)
}

// ── sub-slice empty (same indices) ──

fn test_sub_slice_empty() {
    s := []i32{1, 2, 3}
    t := s[1..1]
    assert(len(t) == 0)
}

// ── sub-slice of a sub-slice ──

fn test_sub_slice_chained() {
    s := []i32{1, 2, 3, 4, 5, 6, 7}
    t := s[1..6]
    u := t[1..4]
    assert(len(u) == 3)
    assert(u[0] == 3)
    assert(u[1] == 4)
    assert(u[2] == 5)
}

// ── sub-slice from start ──

fn test_sub_slice_from_zero() {
    s := []i32{10, 20, 30, 40}
    t := s[0..2]
    assert(len(t) == 2)
    assert(t[0] == 10)
    assert(t[1] == 20)
}

// ── sub-slice to end ──

fn test_sub_slice_to_end() {
    s := []i32{10, 20, 30, 40}
    t := s[3..4]
    assert(len(t) == 1)
    assert(t[0] == 40)
}
