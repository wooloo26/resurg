// v0.2.0 — Tuples ((A, B, …))

// ── basic tuple creation and access ──
fn test_tuple_pair() {
    t := (1, 2)
    assert(t.0 == 1)
    assert(t.1 == 2)
}

fn test_tuple_triple() {
    t := (10, true, "hello")
    assert(t.0 == 10)
    assert(t.1 == true)
    assert(t.2 == "hello")
}

// ── tuple with explicit type ──
fn test_tuple_typed() {
    var t: (i32, bool) = (42, false)
    assert(t.0 == 42)
    assert(t.1 == false)
}

fn test_tuple_typed_triple() {
    var t: (i32, f64, str) = (1, 3.14, "pi")
    assert(t.0 == 1)
    assert(t.1 == 3.14)
    assert(t.2 == "pi")
}

// ── tuple equality ──
fn test_tuple_equality() {
    a := (1, 2)
    b := (1, 2)
    c := (2, 1)
    assert(a == b)
    assert(a != c)
}

// ── tuple with different types ──
fn test_tuple_mixed_types() {
    t := (42, 3.14, true, "test")
    assert(t.0 == 42)
    assert(t.1 == 3.14)
    assert(t.2 == true)
    assert(t.3 == "test")
}

// ── nested tuples ──
fn test_tuple_nested() {
    t := ((1, 2), (3, 4))
    assert(t.0.0 == 1)
    assert(t.0.1 == 2)
    assert(t.1.0 == 3)
    assert(t.1.1 == 4)
}

// ── tuple returned from function ──
fn min_max(a: i32, b: i32) -> (i32, i32) {
    if a < b { (a, b) } else { (b, a) }
}

fn test_tuple_return() {
    result := min_max(10, 5)
    assert(result.0 == 5)
    assert(result.1 == 10)
}

fn test_tuple_return_equal() {
    result := min_max(7, 7)
    assert(result.0 == 7)
    assert(result.1 == 7)
}

// ── tuple as function parameter ──
fn sum_pair(p: (i32, i32)) -> i32 {
    p.0 + p.1
}

fn test_tuple_parameter() {
    assert(sum_pair((3, 4)) == 7)
    assert(sum_pair((0, 0)) == 0)
    assert(sum_pair((-5, 5)) == 0)
}

// ── tuple copy semantics ──
fn test_tuple_copy() {
    var a: (i32, i32) = (1, 2)
    var b: (i32, i32) = a
    // tuples are value types — modifying b should not affect a
    assert(a.0 == 1)
    assert(b.0 == 1)
}

// ── tuple in control flow ──
fn test_tuple_in_if() {
    flag := true
    t := if flag { (1, "yes") } else { (0, "no") }
    assert(t.0 == 1)
    assert(t.1 == "yes")
}

// ── unit is the zero-size type ──
fn test_unit_return() -> unit {
    // functions returning unit produce no value
}
