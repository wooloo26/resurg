// v0.8.2 — Default None for var x: ?T

// ── var with ?T defaults to None ──

fn test_default_none_i32() {
    var x: ?i32
    match x {
        Some(_) => assert(false),
        None => assert(true),
    }
}

fn test_default_none_str() {
    var x: ?str
    match x {
        Some(_) => assert(false),
        None => assert(true),
    }
}

fn test_default_none_bool() {
    var x: ?bool
    match x {
        Some(_) => assert(false),
        None => assert(true),
    }
}

// ── can reassign from default None to Some ──

fn test_reassign_none_to_some() {
    var x: ?i32
    match x {
        Some(_) => assert(false),
        None => assert(true),
    }
    x = Some(42)
    match x {
        Some(v) => assert(v == 42),
        None => assert(false),
    }
}

// ── can reassign from Some back to None ──

fn test_reassign_some_to_none() {
    var x: ?i32 = Some(10)
    match x {
        Some(v) => assert(v == 10),
        None => assert(false),
    }
    x = None
    match x {
        Some(_) => assert(false),
        None => assert(true),
    }
}
