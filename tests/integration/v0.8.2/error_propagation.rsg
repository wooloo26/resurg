// v0.8.2 — Postfix ! error propagation

fn divide(a: f64, b: f64) -> f64 ! str {
    if b == 0.0 { Err("division by zero") }
    else { Ok(a / b) }
}

// ── postfix ! propagates Err to caller ──

fn calc_ok() -> f64 ! str {
    x := divide(10.0, 2.0)!
    y := divide(x, 5.0)!
    Ok(y)
}

fn test_propagation_ok() {
    result := calc_ok()
    match result {
        Ok(v) => assert(v == 1.0),
        Err(_) => assert(false),
    }
}

fn calc_err() -> f64 ! str {
    x := divide(10.0, 0.0)!
    Ok(x)
}

fn test_propagation_err() {
    result := calc_err()
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e == "division by zero"),
    }
}

// ── chained propagation ──

fn multi_step() -> f64 ! str {
    a := divide(100.0, 4.0)!
    b := divide(a, 5.0)!
    c := divide(b, 0.0)!
    Ok(c)
}

fn test_chained_propagation() {
    result := multi_step()
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e == "division by zero"),
    }
}

// ── propagation unwraps Ok ──

fn add_results() -> i32 ! str {
    a := safe_parse("10")!
    b := safe_parse("20")!
    Ok(a + b)
}

fn safe_parse(s: str) -> i32 ! str {
    if s == "10" { Ok(10) }
    else if s == "20" { Ok(20) }
    else { Err("parse error") }
}

fn test_propagation_unwraps_ok() {
    result := add_results()
    match result {
        Ok(v) => assert(v == 30),
        Err(_) => assert(false),
    }
}
