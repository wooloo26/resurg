// v0.1.0 — Assert (runtime assertion) and comments

// This is a single-line comment
// Another comment with special chars: !@#$%^&*()


// ── assert without message ──
fn test_assert_true() {
    assert(true)
    assert(1 == 1)
    assert(1 + 1 == 2)
}

// ── assert with message ──
fn test_assert_with_message() {
    x := 42
    assert(x == 42, "x should be 42")
    assert(x > 0, "x must be positive")
    assert(x != 0, "x must not be zero")
}

// ── assert with computed expressions ──
fn test_assert_expressions() {
    a := 10
    b := 20
    assert(a + b == 30, "addition failed")
    assert(a * b == 200, "multiplication failed")
    assert(b - a == 10, "subtraction failed")
    assert(b / a == 2, "division failed")
}

// ── assert with function results ──
fn is_adult(age: i32) = age >= 18

fn test_assert_function_result() {
    assert(is_adult(18), "18 should be adult")
    assert(is_adult(25), "25 should be adult")
    assert(!is_adult(10), "10 should not be adult")
}

// ── assert with bool logic ──
fn test_assert_bool_logic() {
    assert(true && true)
    assert(true || false)
    assert(!(false && true))
    assert(!(false || false))
}

// ── comments do not affect execution ──
fn test_comments_are_ignored() {
    x := 5 // this is an inline comment
    // x = 10   <-- this line is commented out
    assert(x == 5) // should still be 5
}

// ── assert with f64 values ──
fn test_assert_f64() {
    pi := 3.14
    assert(pi == 3.14)
    assert(pi > 3.0, "pi should be > 3")
    assert(pi < 4.0, "pi should be < 4")
    assert(1.5 + 1.5 == 3.0)
}

// ── assert with u32 values ──
fn test_assert_u32() {
    var x: u32 = 100
    assert(x == 100)
    assert(x > 50, "x should be > 50")
    assert(x != 0, "x should not be zero")
}

// ── assert with str values ──
fn test_assert_str() {
    s := "hello"
    assert(s == "hello")
    assert(s != "world", "s should not be world")
    assert(s != "", "s should not be empty")
}

// ── comments on declarations and between statements ──
fn test_comments_between_statements() {
    // comment before declaration
    a := 1
    // comment between declarations
    b := 2
    // comment before assert
    assert(a + b == 3) // comment at the end
}

// ── assert with negated conditions ──
fn test_assert_negation() {
    assert(!false)
    assert(!false, "negating false should be true")
    assert(!(1 == 2))
    assert(!(1 > 2), "1 is not greater than 2")
}
