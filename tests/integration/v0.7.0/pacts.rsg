// v0.7.0 — Pact definition: required methods, conformance via ext impl

// ── pact with required method ──

pact Printable {
    fn to_string() -> str
}

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0
}

ext Point impl Printable {
    fn to_string(p) -> str { "point" }
}

// ── conforming struct can be instantiated and used ──

fn test_basic_conformance() {
    p := Point { x = 3.0, y = 4.0 }
    s := p.to_string()
    assert(s == "point")
}

// ── pact with multiple required methods ──

pact Shape {
    fn area() -> f64
    fn perimeter() -> f64
}

struct Rectangle {
    width: f64 = 0.0
    height: f64 = 0.0
}

ext Rectangle impl Shape {
    fn area(r) -> f64 { r.width * r.height }
    fn perimeter(r) -> f64 { 2.0 * (r.width + r.height) }
}

fn test_multiple_required_methods() {
    r := Rectangle { width = 3.0, height = 4.0 }
    assert(r.area() == 12.0)
    assert(r.perimeter() == 14.0)
}

// ── pact with required method + extra method ──

pact Describable {
    fn describe() -> str
}

struct Animal {
    name: str
    sound: str = ""
}

ext Animal impl Describable {
    fn describe(a) -> str { "{a.name} says {a.sound}" }
}

fn test_field_and_method() {
    a := Animal { name = "Dog", sound = "woof" }
    assert(a.describe() == "Dog says woof")
    assert(a.name == "Dog")
}
