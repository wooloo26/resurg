// v0.7.0 — Pact definition: required fields, required methods, conformance
module test_pacts

// ── pact with required field and required method ──

pact Printable {
    fn to_string() -> str
}

struct Point: Printable {
    x: f64 = 0.0
    y: f64 = 0.0

    fn to_string(p) -> str {
        "point"
    }
}

// ── pact with required field ──

pact Named {
    name: str
}

struct User: Named {
    name: str
    age: i32 = 0
}

// ── conforming struct can be instantiated and used ──

fn test_basic_conformance() {
    p := Point { x = 3.0, y = 4.0 }
    s := p.to_string()
    assert(s == "point")
}

fn test_required_field() {
    u := User { name = "Alice", age = 30 }
    assert(u.name == "Alice")
    assert(u.age == 30)
}

// ── pact with required field and method combined ──

pact Describable {
    name: str
    fn describe() -> str
}

struct Animal: Describable {
    name: str
    sound: str = ""

    fn describe(a) -> str {
        "{a.name} says {a.sound}"
    }
}

fn test_field_and_method() {
    a := Animal { name = "Dog", sound = "woof" }
    assert(a.describe() == "Dog says woof")
    assert(a.name == "Dog")
}

// ── pact with multiple required methods ──

pact Shape {
    fn area() -> f64
    fn perimeter() -> f64
}

struct Rectangle: Shape {
    width: f64 = 0.0
    height: f64 = 0.0

    fn area(r) -> f64 {
        r.width * r.height
    }

    fn perimeter(r) -> f64 {
        2.0 * (r.width + r.height)
    }
}

fn test_multiple_required_methods() {
    r := Rectangle { width = 3.0, height = 4.0 }
    assert(r.area() == 12.0)
    assert(r.perimeter() == 14.0)
}
