// v0.7.0 — Constraint aliases: pact composition
module test_pact_aliases

// ── base pacts ──

pact HasName {
    name: str
}

pact HasAge {
    age: i32
}

// ── constraint alias using brace syntax ──

pact Person {
    HasName
    HasAge
}

struct Employee: Person {
    name: str
    age: i32 = 0
    role: str = ""
}

fn test_constraint_alias_brace() {
    e := Employee { name = "Alice", age = 30, role = "dev" }
    assert(e.name == "Alice")
    assert(e.age == 30)
}

// ── constraint alias with method requirements ──

pact Displayable {
    fn display() -> str
}

pact Identifiable {
    id: i32
}

pact Presentable {
    Displayable
    Identifiable
}

struct Widget: Presentable {
    id: i32 = 0
    label: str = ""

    fn display(w) -> str {
        "Widget#{w.id}: {w.label}"
    }
}

fn test_alias_with_methods() {
    w := Widget { id = 1, label = "gear" }
    assert(w.display() == "Widget#1: gear")
    assert(w.id == 1)
}

// ── constraint alias using equals syntax ──

pact Vocal {
    fn speak() -> str
}

pact Social = HasName + Vocal

struct Robot: Social {
    name: str

    fn speak(r) -> str {
        "I am {r.name}"
    }
}

fn test_constraint_alias_equals() {
    r := Robot { name = "R2D2" }
    assert(r.name == "R2D2")
    assert(r.speak() == "I am R2D2")
}
