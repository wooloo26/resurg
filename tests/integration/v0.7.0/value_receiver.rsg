// v0.7.0 — Value receivers: copy semantics vs pointer receivers
module test_value_receiver

// ── value receiver reads fields (copy) ──

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0

    fn sum(p) -> f64 {
        p.x + p.y
    }

    fn distance_squared(p) -> f64 {
        p.x * p.x + p.y * p.y
    }

    fn set_x(mut *p, x: f64) {
        p.x = x
    }

    fn translate(mut *p, dx: f64, dy: f64) {
        p.x = p.x + dx
        p.y = p.y + dy
    }
}

fn test_value_receiver_basic() {
    p := Point { x = 3.0, y = 4.0 }
    assert(p.sum() == 7.0)
    assert(p.distance_squared() == 25.0)
}

// ── value receiver does not mutate the original ──

fn test_value_receiver_no_mutation() {
    p := Point { x = 1.0, y = 2.0 }
    s := p.sum()
    assert(s == 3.0)
    assert(p.x == 1.0)
    assert(p.y == 2.0)
}

// ── pointer receiver mutates the original ──

fn test_pointer_receiver_mutates() {
    p := Point { x = 1.0, y = 2.0 }
    p.set_x(10.0)
    assert(p.x == 10.0)
    assert(p.y == 2.0)
}

// ── mix value and pointer receivers ──

fn test_value_and_pointer_mix() {
    p := Point { x = 1.0, y = 2.0 }
    assert(p.sum() == 3.0)
    p.translate(3.0, 4.0)
    assert(p.sum() == 10.0)
    assert(p.x == 4.0)
    assert(p.y == 6.0)
}

// ── value receiver on heap-allocated pointer ──

fn test_value_receiver_on_pointer() {
    p := &Point { x = 5.0, y = 6.0 }
    assert(p.sum() == 11.0)
    p.set_x(20.0)
    assert(p.sum() == 26.0)
}

// ── expression-bodied value receiver ──

struct Counter {
    value: i32 = 0

    fn get(c) = c.value

    fn increment(mut *c) {
        c.value = c.value + 1
    }
}

fn test_expression_body_value_receiver() {
    c := Counter {}
    assert(c.get() == 0)
    c.increment()
    assert(c.get() == 1)
    c.increment()
    c.increment()
    assert(c.get() == 3)
}

// ── value receiver with extra params ──

struct Rectangle {
    width: f64 = 0.0
    height: f64 = 0.0

    fn area(r) -> f64 {
        r.width * r.height
    }

    fn perimeter(r) -> f64 {
        2.0 * (r.width + r.height)
    }

    fn is_square(r) -> bool {
        r.width == r.height
    }

    fn scale(mut *r, factor: f64) {
        r.width = r.width * factor
        r.height = r.height * factor
    }
}

fn test_rectangle_value_receivers() {
    r := Rectangle { width = 3.0, height = 4.0 }
    assert(r.area() == 12.0)
    assert(r.perimeter() == 14.0)
    assert(r.is_square() == false)
}

fn test_rectangle_pointer_receiver() {
    r := Rectangle { width = 2.0, height = 3.0 }
    r.scale(2.0)
    assert(r.width == 4.0)
    assert(r.height == 6.0)
    assert(r.area() == 24.0)
}

// ── value receiver in expression ──

fn test_method_in_expression() {
    r := Rectangle { width = 3.0, height = 4.0 }
    total := r.area() + r.perimeter()
    assert(total == 26.0)
}

// ── pact value receiver: default method ──

pact Labeled {
    label: str
    fn display(thing) -> str {
        "Label: {thing.label}"
    }
}

struct Box: Labeled {
    label: str
    size: i32 = 0
}

fn test_pact_default_value_receiver() {
    b := Box { label = "Fragile", size = 10 }
    assert(b.display() == "Label: Fragile")
}

// ── pact value receiver: override default ──

pact Describable {
    name: str
    fn describe(thing) -> str {
        thing.name
    }
}

struct Product: Describable {
    name: str
    price: f64 = 0.0
    fn describe(p) -> str {
        "{p.name} costs {p.price}"
    }
}

struct SimpleItem: Describable {
    name: str
}

fn test_pact_override_value_receiver() {
    p := Product { name = "Widget", price = 9.99 }
    assert(p.describe() == "Widget costs 9.99")
    s := SimpleItem { name = "Thing" }
    assert(s.describe() == "Thing")
}

// ── pact mix: value receiver + pointer receiver ──

pact Animal {
    name: str
    fn get_name(animal) = animal.name
    fn set_name(mut *animal, new_name: str) {
        animal.name = new_name
    }
}

struct Dog: Animal {
    name: str
    breed: str = ""
}

fn test_pact_mixed_receivers() {
    d := Dog { name = "Rex", breed = "Labrador" }
    assert(d.get_name() == "Rex")
    d.set_name(new_name = "Buddy")
    assert(d.get_name() == "Buddy")
}