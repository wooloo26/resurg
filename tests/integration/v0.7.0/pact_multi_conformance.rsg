// v0.7.0 — Explicit conformance to multiple pacts
module test_pact_multi

// ── two field-only pacts ──

pact Named {
    name: str
}

pact Aged {
    age: i32
}

struct Person: Named + Aged {
    name: str
    age: i32 = 0
}

fn test_multi_conformance_fields() {
    p := Person { name = "Alice", age = 30 }
    assert(p.name == "Alice")
    assert(p.age == 30)
}

// ── multiple pacts with methods ──

pact Greetable {
    name: str
    fn greet(thing) -> str {
        "Hi, {thing.name}!"
    }
}

pact Measurable {
    fn size() -> i32
}

struct Team: Greetable + Measurable {
    name: str
    members: i32 = 0

    fn size(t) -> i32 {
        t.members
    }
}

fn test_multi_conformance_methods() {
    t := Team { name = "Alpha", members = 5 }
    assert(t.greet() == "Hi, Alpha!")
    assert(t.size() == 5)
}

// ── three pacts ──

pact HasId {
    id: i32
}

pact HasName {
    name: str
}

pact HasLabel {
    fn label() -> str
}

struct Entity: HasId + HasName + HasLabel {
    id: i32 = 0
    name: str

    fn label(e) -> str {
        "{e.id}: {e.name}"
    }
}

fn test_triple_conformance() {
    e := Entity { id = 42, name = "widget" }
    assert(e.id == 42)
    assert(e.name == "widget")
    assert(e.label() == "42: widget")
}
