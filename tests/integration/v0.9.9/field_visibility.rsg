// v0.9.9 — pub struct fields: pub fields accessible, private fields restricted

mod field_vis_mod

use self::field_vis_mod::Config
use self::field_vis_mod::make_config
use self::field_vis_mod::read_secret

// ── access pub fields ──

fn test_pub_field_access() {
    c := make_config()
    assert(c.name == "test")
    assert(c.enabled == true)
}

// ── construct with pub fields only, private gets default ──

fn test_pub_field_construction() {
    c := Config { name = "custom", enabled = false }
    assert(c.name == "custom")
    assert(c.enabled == false)
}

// ── access private field via module-internal accessor ──

fn test_private_field_via_accessor() {
    c := make_config()
    s := read_secret(c)
    assert(s == 99)
}

// ── EXPECT-STDOUT: ──

fn main() {
    test_pub_field_access()
    test_pub_field_construction()
    test_private_field_via_accessor()
}
