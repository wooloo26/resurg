// SKIP: module file, not a standalone test

/// Addition of two integers.
pub fn add(a: i32, b: i32) -> i32 { a + b }

/// Multiplication of two integers.
pub fn multiply(a: i32, b: i32) -> i32 { a * b }

/// A 2D point.
pub struct Point {
    pub x: f64 = 0.0
    pub y: f64 = 0.0
}

/// Arithmetic operations.
pub enum Op {
    Add,
    Sub,
    Mul,
}
