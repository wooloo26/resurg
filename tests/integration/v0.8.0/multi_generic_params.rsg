// v0.8.0 — Multiple generic parameters with mixed bounds
module test_multi_params

// ── pacts ──

pact Display {
    fn to_display() -> str
}

pact HasName {
    name: str
}

// ── two type params, no bounds ──

fn swap<T, U>(a: T, b: U) -> (U, T) {
    (b, a)
}

// ── three type params, no bounds ──

fn triple<A, B, C>(a: A, b: B, c: C) -> (A, B, C) {
    (a, b, c)
}

// ── two type params, each with different bounds ──

fn show_named<T: Display, U: HasName>(x: T, y: U) -> str {
    y.name
}

// ── conforming structs ──

struct Tag: Display {
    label: str
    fn to_display(t) -> str {
        t.label
    }
}

struct Pet: HasName {
    name: str
}

fn test_swap() {
    result := swap<i32, str>(42, "world")
    assert(result.0 == "world")
    assert(result.1 == 42)
}

fn test_triple() {
    result := triple<i32, bool, char>(1, true, 'x')
    assert(result.0 == 1)
    assert(result.1 == true)
    assert(result.2 == 'x')
}

fn test_mixed_bounds() {
    t := Tag { label = "animal" }
    p := Pet { name = "Rex" }
    s := show_named<Tag, Pet>(t, p)
    assert(s == "Rex")
}
