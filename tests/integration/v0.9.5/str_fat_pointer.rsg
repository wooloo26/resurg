// v0.9.5 — str is fat pointer (data + length)

// ── str.len on literal ──

fn test_str_len() {
    s := "hello"
    assert(s.len == 5)
}

// ── str.len on empty string ──

fn test_str_empty_len() {
    s := ""
    assert(s.len == 0)
}

// ── str.len on single character ──

fn test_str_single_char_len() {
    s := "a"
    assert(s.len == 1)
}

// ── str.len with spaces ──

fn test_str_len_with_spaces() {
    s := "hello world"
    assert(s.len == 11)
}

// ── str.len with different lengths ──

fn test_str_len_two() {
    s := "ab"
    assert(s.len == 2)
}

fn test_str_len_ten() {
    s := "0123456789"
    assert(s.len == 10)
}

// ── str.len with explicit type annotation ──

fn test_str_len_typed() {
    var s: str = "test"
    assert(s.len == 4)
}

// ── str.len via function parameter ──

fn string_length(s: str) -> i32 {
    s.len
}

fn test_str_len_param() {
    assert(string_length("abc") == 3)
    assert(string_length("") == 0)
    assert(string_length("x") == 1)
}

// ── str.len after copy ──

fn test_str_len_copy() {
    a := "test"
    b := a
    assert(a.len == 4)
    assert(b.len == 4)
}

// ── str equality still works ──

fn test_str_equality() {
    a := "hello"
    b := "hello"
    c := "world"
    assert(a == b)
    assert(a != c)
}

// ── str.len on interpolated string ──

fn test_str_len_interpolated() {
    name := "Bob"
    s := "Hi {name}"
    assert(s.len == 6)
}

// ── str.len on longer string ──

fn test_str_len_long() {
    s := "the quick brown fox"
    assert(s.len == 19)
}
