// v0.9.5 — str is fat pointer (data + length)

// ── len(str) on literal ──

fn test_str_len() {
    s := "hello"
    assert(len(s) == 5)
}

// ── len(str) on empty string ──

fn test_str_empty_len() {
    s := ""
    assert(len(s) == 0)
}

// ── len(str) on single character ──

fn test_str_single_char_len() {
    s := "a"
    assert(len(s) == 1)
}

// ── len(str) with spaces ──

fn test_str_len_with_spaces() {
    s := "hello world"
    assert(len(s) == 11)
}

// ── len(str) with different lengths ──

fn test_str_len_two() {
    s := "ab"
    assert(len(s) == 2)
}

fn test_str_len_ten() {
    s := "0123456789"
    assert(len(s) == 10)
}

// ── len(str) with explicit type annotation ──

fn test_str_len_typed() {
    var s: str = "test"
    assert(len(s) == 4)
}

// ── len(str) via function parameter ──

fn string_length(s: str) -> i32 {
    len(s)
}

fn test_str_len_param() {
    assert(string_length("abc") == 3)
    assert(string_length("") == 0)
    assert(string_length("x") == 1)
}

// ── len(str) after copy ──

fn test_str_len_copy() {
    a := "test"
    b := a
    assert(len(a) == 4)
    assert(len(b) == 4)
}

// ── str equality still works ──

fn test_str_equality() {
    a := "hello"
    b := "hello"
    c := "world"
    assert(a == b)
    assert(a != c)
}

// ── len(str) on interpolated string ──

fn test_str_len_interpolated() {
    name := "Bob"
    s := "Hi {name}"
    assert(len(s) == 6)
}

// ── len(str) on longer string ──

fn test_str_len_long() {
    s := "the quick brown fox"
    assert(len(s) == 19)
}
