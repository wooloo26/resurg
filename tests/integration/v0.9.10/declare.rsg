// v0.9.10 — declare: external declarations for functions and variables
// EXPECT-STDOUT: hello from declare
// EXPECT-STDOUT: assert works via declare

// ── declare fn: print, println, assert are now declared, not builtin ──

// These are implicitly declared by the compiler (replacing builtins):
// pub declare fn print(s: str)
// pub declare fn println(s: str)
// pub declare fn assert(cond: bool, msg: ?str)

fn test_declared_println() {
    println("hello from declare")
}

fn test_declared_assert() {
    assert(true)
    assert(1 + 1 == 2)
    assert(1 + 1 == 2, "math works")
    println("assert works via declare")
}

fn test_declared_print() {
    // print still works as before
    x := 42
    assert(x == 42)
}

// ── declare fn in ext block: len on slices ──

fn test_declared_len_slice() {
    s := []i32{1, 2, 3, 4, 5}
    assert(len(s) == 5)
}

fn test_declared_len_empty_slice() {
    s := []i32{}
    assert(len(s) == 0)
}

fn test_declared_len_str() {
    s := "hello"
    assert(len(s) == 5)
}

fn test_declared_len_empty_str() {
    s := ""
    assert(len(s) == 0)
}
