// pub decl: public declared functions in ext blocks
// EXPECT-STDOUT: pub decl ext works

// ── pub decl fn for len is available via prelude ext blocks ──
// Per README § 13:
//   ext str { pub decl fn len(s) }
//   ext<T> []T { pub decl fn len(s) }
//   ext<T, comptime N: usize> [N]T { pub decl fn len(s) }

fn test_prelude_dot_len_str() {
    s := "hello"
    assert(s.len() == 5, "")
    assert("".len() == 0, "")
}

fn test_prelude_dot_len_slice() {
    s := []i32{1, 2, 3}
    assert(s.len() == 3, "")
    assert(([]i32{}).len() == 0, "")
}

fn test_prelude_dot_len_array() {
    arr := [3]i32{1, 2, 3}
    assert(arr.len() == 3, "")
}

// ── pub fn works inside ext block (within same module scope) ──

struct Counter {
    value: i32 = 0
}

ext Counter {
    pub fn get_value(c) -> i32 { c.value }
}

fn test_pub_fn_in_ext_block() {
    c := Counter { value = 42 }
    assert(c.get_value() == 42, "")
    println("pub decl ext works")
}
