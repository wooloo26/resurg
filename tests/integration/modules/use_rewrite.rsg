// Rewrite use: path-style selective imports with :: before braces

// ── qualified access without use ──

fn test_qualified_access() {
    result := math::add(2, 3)
    assert(result == 5, "")
    product := math::multiply(4, 5)
    assert(product == 20, "")
}

// ── single selective import with :: ──

mod math {
    pub fn add(a: i32, b: i32) -> i32 = a + b
    pub fn multiply(a: i32, b: i32) -> i32 = a * b
    pub fn subtract(a: i32, b: i32) -> i32 = a - b
}

use math::{add}

fn test_use_single_import() {
    assert(add(2, 3) == 5, "")
}

// ── multiple selective imports with :: ──

use math::{multiply, subtract}

fn test_use_multiple_imports() {
    assert(multiply(4, 5) == 20, "")
    assert(subtract(10, 3) == 7, "")
}

// ── alias import with :: ──

use math::{add as sum}

fn test_use_alias() {
    assert(sum(10, 20) == 30, "")
}

// ── mixed alias and plain imports ──

mod utils {
    pub fn double(x: i32) -> i32 = x * 2
    pub fn triple(x: i32) -> i32 = x * 3
    pub fn negate(x: i32) -> i32 = 0 - x
}

use utils::{double, triple as t, negate}

fn test_use_mixed_alias() {
    assert(double(5) == 10, "")
    assert(t(5) == 15, "")
    assert(negate(5) == -5, "")
}

// ── single path import (no braces) ──

mod ops {
    pub fn square(x: i32) -> i32 = x * x
}

use ops::square

fn test_use_path_import() {
    assert(square(7) == 49, "")
}

// ── nested module path with :: selective ──

mod outer {
    pub mod inner {
        pub fn greet() -> str = "hello"
        pub fn farewell() -> str = "bye"
    }
}

use outer::inner::{greet, farewell}

fn test_use_nested_module_path() {
    assert(greet() == "hello", "")
    assert(farewell() == "bye", "")
}

// ── super:: import inside nested module ──

mod parent {
    pub fn parent_val() -> i32 = 100

    pub mod child {
        use super::parent_val

        pub fn call_parent() -> i32 {
            parent_val()
        }
    }
}

fn test_use_super_import() {
    assert(parent::child::call_parent() == 100, "")
}

// ── super::super:: import through two levels ──

mod top {
    pub fn root_fn() -> i32 = 42

    pub mod mid {
        pub mod bottom {
            use super::super::root_fn

            pub fn deep_call() -> i32 {
                root_fn()
            }
        }
    }
}

fn test_use_super_super() {
    assert(top::mid::bottom::deep_call() == 42, "")
}

// ── nested path single import ──

use outer::inner::greet as hi

fn test_use_nested_path_single() {
    assert(hi() == "hello", "")
}
