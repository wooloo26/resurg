// Decl functions resolve from builtin.rsg (not hardcoded)
// EXPECT-STDOUT: decl resolve works

// ── panic caught via catch_panic ──

fn test_panic_catch() {
    result := catch_panic(|| -> i32 {
        panic("expected panic")
    })
    match result {
        Ok(_) => assert(false, ""),
        Err(_) => assert(true, ""),
    }
}

// ── catch_panic returns Result<T, str> ──

fn test_catch_returns_result() {
    result := catch_panic(|| -> i32 {
        panic("caught")
    })
    match result {
        Ok(_) => assert(false, ""),
        Err(msg) => assert(msg == "caught", ""),
    }
}

// ── print/println accept str ──

fn test_print_str() {
    println("decl resolve works")
    print("")
}

// ── assert accepts bool (with optional msg) ──

fn test_assert_forms() {
    assert(true, "")
    assert(1 == 1, "one equals one")
}
