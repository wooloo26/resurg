// v0.9.0 — Closures / lambdas: |params| body syntax
module test_closures

// ── basic closure with single param ──

fn apply(f: fn(i32) -> i32, x: i32) -> i32 {
    f(x)
}

fn test_closure_basic() {
    result := apply(|x| x * 2, 5)
    assert(result == 10)
}

// ── closure with expression body ──

fn test_closure_expr_body() {
    result := apply(|x| x + 1, 10)
    assert(result == 11)
}

// ── closure with block body ──

fn test_closure_block_body() {
    result := apply(|x| {
        doubled := x * 2
        doubled + 1
    }, 5)
    assert(result == 11)
}

// ── closure with multiple params ──

fn apply2(f: fn(i32, i32) -> i32, a: i32, b: i32) -> i32 {
    f(a, b)
}

fn test_closure_multi_param() {
    result := apply2(|a, b| a + b, 3, 4)
    assert(result == 7)
}

// ── closure stored in variable ──

fn test_closure_in_variable() {
    doubler := |x: i32| -> i32 { x * 2 }
    assert(doubler(5) == 10)
}

// ── closure with no params ──

fn run(f: fn() -> i32) -> i32 {
    f()
}

fn test_closure_no_params() {
    result := run(|| 42)
    assert(result == 42)
}

// ── closure returning bool ──

fn test_closure_returns_bool() {
    is_positive := |x: i32| -> bool { x > 0 }
    assert(is_positive(5) == true)
    assert(is_positive(-1) == false)
}

// ── closure passed to higher-order function ──

fn transform(f: fn(i32) -> i32, x: i32) -> i32 {
    f(x)
}

fn test_closure_higher_order() {
    result := transform(|x| x * x, 4)
    assert(result == 16)
}
