// v0.9.0 — Closure variable capture: closures bind outer scope values
module test_closure_capture

// ── capture local variable ──

fn apply(f: fn(i32) -> i32, x: i32) -> i32 {
    f(x)
}

fn test_capture_local() {
    offset := 10
    result := apply(|x| x + offset, 5)
    assert(result == 15)
}

// ── capture multiple variables ──

fn apply2(f: fn(i32) -> i32, x: i32) -> i32 {
    f(x)
}

fn test_capture_multiple() {
    a := 2
    b := 3
    result := apply2(|x| x * a + b, 4)
    assert(result == 11)
}

// ── capture function parameter ──

fn make_adder(n: i32) -> fn(i32) -> i32 {
    |x| x + n
}

fn test_capture_param() {
    add5 := make_adder(5)
    assert(add5(10) == 15)
    assert(add5(0) == 5)
}

// ── capture in nested scope ──

fn test_capture_nested_scope() {
    outer := 100
    f := {
        inner := 10
        |x: i32| -> i32 { x + outer + inner }
    }
    assert(f(1) == 111)
}

// ── captured variable is snapshot, not reference (value capture) ──

fn test_capture_snapshot() {
    x := 10
    f := |y: i32| -> i32 { y + x }
    x = 20
    // closure captured x=10 at definition time
    assert(f(5) == 15)
}

// ── capture bool ──

fn test_capture_bool() {
    flag := true
    check := |x: i32| -> bool {
        if flag { x > 0 } else { x < 0 }
    }
    assert(check(5) == true)
    assert(check(-5) == false)
}

// ── capture string ──

fn run_str(f: Fn() -> str) -> str {
    f()
}

fn test_capture_str() {
    greeting := "hello"
    f := || greeting
    assert(run_str(f) == "hello")
}
