// Tracing garbage collector

struct Point {
    x: f64 = 0.0
    y: f64 = 0.0
}

struct Node {
    value: i32 = 0
    label: str
}

struct Pair {
    left: *Point
    right: *Point
}

// ── live heap objects survive GC ──

fn test_heap_alloc_survives() {
    p := &Point { x = 1.0, y = 2.0 }
    // allocate many temporaries to trigger GC pressure
    for 0..500 |i| {
        tmp := &Point { x = 0.0, y = 0.0 }
    }
    // p must still be alive
    assert(p.x == 1.0)
    assert(p.y == 2.0)
}

// ── multiple live roots survive ──

fn test_multiple_roots_survive() {
    a := &Point { x = 10.0, y = 20.0 }
    b := &Point { x = 30.0, y = 40.0 }
    c := &Node { value = 99, label = "hello" }
    for 0..500 |i| {
        tmp := &Point {}
    }
    assert(a.x == 10.0)
    assert(a.y == 20.0)
    assert(b.x == 30.0)
    assert(b.y == 40.0)
    assert(c.value == 99)
    assert(c.label == "hello")
}

// ── pointer aliasing remains valid after GC pressure ──

fn test_aliasing_survives_gc() {
    a := &Point { x = 5.0, y = 6.0 }
    b := a
    for 0..500 |i| {
        tmp := &Point {}
    }
    b.x = 99.0
    assert(a.x == 99.0)
    assert(b.x == 99.0)
}

// ── pointer returned from function survives GC pressure ──

fn make_point(x: f64, y: f64) -> *Point {
    &Point { x = x, y = y }
}

fn test_returned_pointer_survives() {
    p := make_point(7.0, 8.0)
    for 0..500 |i| {
        tmp := make_point(0.0, 0.0)
    }
    assert(p.x == 7.0)
    assert(p.y == 8.0)
}

// ── nested struct pointers survive GC ──

fn test_nested_pointers_survive() {
    left := &Point { x = 1.0, y = 2.0 }
    right := &Point { x = 3.0, y = 4.0 }
    pair := &Pair { left = left, right = right }
    for 0..500 |i| {
        tmp := &Point {}
    }
    assert(pair.left.x == 1.0)
    assert(pair.left.y == 2.0)
    assert(pair.right.x == 3.0)
    assert(pair.right.y == 4.0)
}

// ── heap-allocated strings managed by GC ──

fn test_string_fields_survive_gc() {
    n := &Node { value = 42, label = "world" }
    for 0..500 |i| {
        tmp := &Node { value = 0, label = "garbage" }
    }
    assert(n.value == 42)
    assert(n.label == "world")
}

// ── mutation through pointer after GC pressure ──

fn set_x(mut p: *Point, v: f64) {
    p.x = v
}

fn test_mutation_after_gc() {
    p := &Point { x = 0.0, y = 0.0 }
    for 0..500 |i| {
        tmp := &Point {}
    }
    set_x(mut p, 123.0)
    assert(p.x == 123.0)
}

// ── heavy allocation in loop with retained references ──

fn test_retained_across_loop() {
    p := &Point { x = 1.0, y = 1.0 }
    for 0..1000 |i| {
        tmp := &Point { x = 0.0, y = 0.0 }
        // p remains valid throughout
        assert(p.x == 1.0)
    }
    assert(p.y == 1.0)
}

// ── value copy semantics preserved under GC ──

fn test_value_copy_independent() {
    p := &Point { x = 10.0, y = 20.0 }
    // value copy: struct fields are copied, not aliased
    x := p.x
    for 0..500 |i| {
        tmp := &Point {}
    }
    p.x = 99.0
    assert(x == 10.0)
    assert(p.x == 99.0)
}
