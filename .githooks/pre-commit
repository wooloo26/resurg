#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-commit: formatting ==="
# Collect all staged C sources and format them
ALL_C=$(git diff --cached --name-only --diff-filter=ACM -- 'src/*.c' 'src/*.h' 'runtime/*.c' 'runtime/*.h' 2>/dev/null)
if [ -n "$ALL_C" ]; then
    for f in $ALL_C; do
        clang-format --style=file -i "$f"
        git add "$f"
    done
    echo "  formatted and staged"
fi

echo "=== pre-commit: running clang-tidy ==="
make tidy

echo "=== pre-commit: building ==="
make all

echo "=== pre-commit: all checks passed ==="
