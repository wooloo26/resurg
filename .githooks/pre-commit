#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-commit: formatting ==="
# Collect all staged C sources and format them
ALL_C=$(git diff --cached --name-only --diff-filter=ACM -- 'src/*.c' 'src/*.h' 'runtime/*.c' 'runtime/*.h' 2>/dev/null)
if [ -n "$ALL_C" ]; then
    for f in $ALL_C; do
        clang-format --style=file -i "$f"
        git add "$f"
    done
    echo "  formatted and staged"
fi

echo "=== pre-commit: running clang-tidy ==="
# Only tidy staged/new .c files (not all sources)
TIDY_C=$(git diff --cached --name-only --diff-filter=ACM -- '*.c' | grep '\.c$' || true)
if [ -n "$TIDY_C" ]; then
    # Ensure compile_commands.json exists
    make build/Makefile
    echo "$TIDY_C" | xargs -P"$(nproc 2>/dev/null || echo 4)" -n1 clang-tidy --quiet -p build
    echo "  clang-tidy passed"
else
    echo "  no staged .c files to tidy"
fi

echo "=== pre-commit: building ==="
make all

echo "=== pre-commit: all checks passed ==="
